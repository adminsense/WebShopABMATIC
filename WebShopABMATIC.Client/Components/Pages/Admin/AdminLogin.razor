@page "/admin/login"
@layout AdminLoginLayout

@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Web.Forms

@inject NavigationManager Navigation

<PageTitle>Sign in</PageTitle>

@code {
    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override void OnInitialized()
    {
        var destination = string.IsNullOrWhiteSpace(ReturnUrl)
            ? "/sign-in?returnUrl=%2Fadmin"
            : $"/sign-in?returnUrl={Uri.EscapeDataString(ReturnUrl)}";

        Navigation.NavigateTo(destination, replace: true);
    }
}
