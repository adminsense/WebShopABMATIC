@page "/admin/users"
@page "/admin/system-users"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOnly)]
@using WebShopABMATIC.Application.Admin.UserAccounts
@using WebShopABMATIC.Application.Common
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Web.Services
@inject IApplicationUserAccountAdminPort AdminPort
@inject IGridExportService GridExport
@implements IAsyncDisposable

<PageTitle>Users</PageTitle>

<div class="entity-page">
    <a class="btn btn-secondary btn-back mb-3" href="/admin/hub/settings" data-enhance-nav="false"><span class="oi oi-arrow-left"></span> Back to settings</a>
    <div class="entity-page-header page-header">
        <h1 class="h3 mb-1"><i class="bi bi-people text-primary"></i> Users</h1>
        <p class="mb-0">All login accounts — webstore customers and admin/manager staff.</p>
    </div>

    @if (!string.IsNullOrEmpty(_tempPasswordMessage))
    {
        <div class="alert alert-success">
            <strong>@_tempPasswordAlertTitle</strong> Temporary password (show once): <code>@_tempPasswordMessage</code>
        </div>
    }

    <div class="card shadow-sm border entity-form-card admin-form-card">
        <AdminEntityFormHeader ExportDisabled="@ExportDisabled" OnExport="ExportGridAsync">
            <Title>@(_isEditing ? "Edit user" : "Create user")</Title>
        </AdminEntityFormHeader>
        <div class="card-body">
            @if (_formLoading) { <p class="text-muted mb-0">Loading…</p> }
            else
            {
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <div class="entity-form-fields"><div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label" for="f-email">Email *</label>
                            <InputText id="f-email" class="form-control form-control-sm" @bind-Value="_model.Email" required autocomplete="off" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="f-firstname">First name *</label>
                            <InputText id="f-firstname" class="form-control form-control-sm" @bind-Value="_model.FirstName" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="f-lastname">Last name *</label>
                            <InputText id="f-lastname" class="form-control form-control-sm" @bind-Value="_model.LastName" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label" for="f-phone">Phone</label>
                            <InputText id="f-phone" class="form-control form-control-sm" @bind-Value="_model.PhoneNumber" />
                        </div>
                        @if (!_isEditing)
                        {
                            <div class="col-md-4">
                                <label class="form-label" for="f-password">Password</label>
                                <InputText id="f-password" type="password" class="form-control form-control-sm" @bind-Value="_model.Password" autocomplete="new-password" />
                                <div class="form-text">Leave empty to generate a temporary password.</div>
                            </div>
                        }
                        <div class="col-md-4">
                            <label class="form-label" for="f-customerid">Customer ID (webstore link)</label>
                            <InputNumber id="f-customerid" class="form-control form-control-sm" @bind-Value="_model.CustomerId" />
                            <div class="form-text">Optional — link to B2B customer record.</div>
                        </div>
                        <div class="col-12 d-flex align-items-end gap-3 flex-wrap">
                            <div class="form-check mb-1">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsAdmin" id="f-admin" />
                                <label class="form-check-label" for="f-admin">Admin</label>
                            </div>
                            <div class="form-check mb-1">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsManager" id="f-manager" />
                                <label class="form-check-label" for="f-manager">Manager</label>
                            </div>
                            <div class="form-check mb-1">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsCustomer" id="f-customer" />
                                <label class="form-check-label" for="f-customer">Webstore customer</label>
                            </div>
                            <div class="form-check mb-1">
                                <InputCheckbox class="form-check-input" @bind-Value="_model.IsActive" id="f-active" />
                                <label class="form-check-label" for="f-active">Active (not locked)</label>
                            </div>
                        </div>
                        @if (_isEditing)
                        {
                            <div class="col-12">
                                <button type="button" class="btn btn-outline-warning btn-sm" @onclick="() => PromptResetPassword(_model.Id, _model.Email)" disabled="@_saving">
                                    <i class="bi bi-key me-1"></i>Reset password
                                </button>
                            </div>
                        }
                        <div class="col-12 d-flex gap-2 pt-1">
                            <button type="submit" class="btn btn-primary" disabled="@_saving">@(_isEditing ? "Update" : "Create")</button>
                            <button type="button" class="btn btn-secondary" @onclick="CancelFormAsync" disabled="@_saving"><i class="bi bi-x me-1"></i>Cancel</button>
                        </div>
                    </div></div>
                </EditForm>
                @if (!string.IsNullOrEmpty(_formError)) { <div class="alert alert-danger mt-3 mb-0">@_formError</div> }
            }
        </div>
    </div>

    <div class="card shadow-sm border entity-grid-card">
        <div class="card-header bg-white entity-grid-toolbar">
            <h2 class="h6 mb-0 fw-bold">User list</h2>
            <AdminGridSearch @bind-Value="_searchDraft" OnSearch="ApplySearchAsync" />
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark"><tr>
                    <th>Email</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Roles</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr></thead>
                <tbody>
                    @if (_loading) { <tr><td colspan="7" class="text-center text-muted py-4">Loading…</td></tr> }
                    else if (!string.IsNullOrEmpty(_gridError)) { <tr><td colspan="7" class="text-center text-danger py-4">@_gridError</td></tr> }
                    else if (_result is null || _result.Items.Count == 0) { <tr><td colspan="7" class="text-center text-muted py-4">No records found.</td></tr> }
                    else { @foreach (var item in _result.Items) {
                        <tr @key="item.Id" class="@(_model.Id == item.Id ? "table-active" : null)">
                            <td>@item.Email</td>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@item.AccountType</td>
                            <td>@FormatRoles(item)</td>
                            <td>@(item.CustomerId?.ToString() ?? "—")</td>
                            <td>@(item.IsActive ? "Active" : "Locked")</td>
                            <td class="text-center"><div class="btn-group btn-group-sm">
                                <a class="btn btn-sm btn-primary" href="@($"/admin/users?edit={Uri.EscapeDataString(item.Id)}")" data-enhance-nav="false" title="Edit user"><i class="bi bi-pencil"></i></a>
                                <button type="button" class="btn btn-sm btn-warning" @onclick="() => PromptResetPassword(item.Id, item.Email)" title="Reset password"><i class="bi bi-key"></i></button>
                            </div></td>
                        </tr> } }
                </tbody>
            </table>
        </div>
        <AdminGridPagination TotalCount="@(_result?.TotalCount ?? 0)" Page="@(_filter.Page)" PageSize="@(_filter.PageSize)" Loading="@_loading" OnPageChanged="ChangePageAsync" />
    </div>
</div>

@if (_showResetConfirm && _resetTarget is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0"><h5 class="modal-title">Reset password</h5><button type="button" class="btn-close" @onclick="CancelReset" disabled="@_resetting"></button></div>
                <div class="modal-body">
                    <p class="mb-2">Set a new password for <strong>@_resetTarget.Email</strong>.</p>
                    <label class="form-label" for="reset-password">New password</label>
                    <InputText id="reset-password" type="password" class="form-control form-control-sm" @bind-Value="_resetPasswordDraft" autocomplete="new-password" />
                    <div class="form-text">Leave empty to generate a temporary password (shown once).</div>
                    @if (!string.IsNullOrEmpty(_resetError)) { <div class="text-danger small mt-2 mb-0">@_resetError</div> }
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" @onclick="CancelReset" disabled="@_resetting">Cancel</button>
                    <button type="button" class="btn btn-warning" @onclick="ConfirmResetAsync" disabled="@_resetting">Reset password</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "edit")] public string? EditId { get; set; }

    private CancellationTokenSource? _cts;
    private ApplicationUserAccountListFilter _filter = new();
    private ApplicationUserAccountEditDto _model = new();
    private string _searchDraft = string.Empty;
    private bool _loading = true, _formLoading, _saving, _disposed, _initialized;
    private string? _formError, _gridError, _tempPasswordMessage, _tempPasswordAlertTitle = "User created.";
    private PagedResult<ApplicationUserAccountDto>? _result;
    private bool _isEditing => !string.IsNullOrWhiteSpace(_model.Id);
    private bool _showResetConfirm, _resetting;
    private string? _resetPasswordDraft, _resetError;
    private ResetTarget? _resetTarget;

    private sealed record ResetTarget(string Id, string Email);

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadGridAsync(_cts.Token);
        if (!string.IsNullOrWhiteSpace(EditId)) await EditAsync(EditId);
        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized || _disposed || string.IsNullOrWhiteSpace(EditId) || _model.Id == EditId) return;
        await EditAsync(EditId);
    }

    private static string FormatRoles(ApplicationUserAccountDto item)
    {
        var roles = new List<string>();
        if (item.IsAdmin) roles.Add("Admin");
        if (item.IsManager) roles.Add("Manager");
        if (item.IsCustomer) roles.Add("Customer");
        return roles.Count == 0 ? "—" : string.Join(", ", roles);
    }

    private async Task LoadGridAsync(CancellationToken ct)
    {
        _loading = true; _gridError = null;
        try { _result = await AdminPort.GetAccountsAsync(_filter, ct); }
        catch (OperationCanceledException) { return; }
        catch (Exception ex) { _result = null; _gridError = ex.Message; }
        finally { _loading = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task ApplySearchAsync() { _filter.Search = _searchDraft; _filter.Page = 1; _cts?.Cancel(); _cts = new CancellationTokenSource(); await LoadGridAsync(_cts.Token); }

    private async Task EditAsync(string id)
    {
        _formLoading = true; _formError = null; _tempPasswordMessage = null;
        try
        {
            var item = await AdminPort.GetForEditAsync(id, _cts?.Token ?? CancellationToken.None);
            if (item is null) { _formError = "Record not found."; return; }
            _model = item;
        }
        finally { _formLoading = false; }
    }

    private async Task SaveAsync()
    {
        _saving = true; _formError = null; _tempPasswordMessage = null;
        try
        {
            var result = await AdminPort.SaveAsync(_model, _cts?.Token ?? CancellationToken.None);
            if (!result.Succeeded)
            {
                _formError = string.Join(" ", result.Errors);
                return;
            }

            if (!string.IsNullOrWhiteSpace(result.TemporaryPassword))
            {
                _tempPasswordMessage = result.TemporaryPassword;
                _tempPasswordAlertTitle = _isEditing ? "Password updated." : "User created.";
            }

            await LoadGridAsync(_cts?.Token ?? CancellationToken.None);
            if (!string.IsNullOrWhiteSpace(result.UserId))
            {
                await EditAsync(result.UserId);
            }
        }
        catch (Exception ex) { _formError = ex.Message; }
        finally { _saving = false; }
    }

    private Task CancelFormAsync()
    {
        _formError = null;
        _tempPasswordMessage = null;
        _model = new ApplicationUserAccountEditDto();
        return Task.CompletedTask;
    }

    private void PromptResetPassword(string id, string email)
    {
        _resetTarget = new ResetTarget(id, email);
        _resetPasswordDraft = null;
        _resetError = null;
        _showResetConfirm = true;
    }

    private void CancelReset()
    {
        _showResetConfirm = false;
        _resetTarget = null;
        _resetPasswordDraft = null;
        _resetError = null;
    }

    private async Task ConfirmResetAsync()
    {
        if (_resetTarget is null) return;
        _resetting = true;
        _resetError = null;
        try
        {
            var result = await AdminPort.ResetPasswordAsync(
                _resetTarget.Id,
                string.IsNullOrWhiteSpace(_resetPasswordDraft) ? null : _resetPasswordDraft,
                _cts?.Token ?? CancellationToken.None);

            if (!result.Succeeded)
            {
                _resetError = string.Join(" ", result.Errors);
                return;
            }

            CancelReset();
            _tempPasswordAlertTitle = "Password reset.";
            _tempPasswordMessage = result.TemporaryPassword ?? "Password updated.";
        }
        finally
        {
            _resetting = false;
        }
    }

    private bool ExportDisabled => _loading || _result is null || _result.Items.Count == 0;

    private async Task ExportGridAsync(string format)
    {
        var request = BuildExportRequest();
        if (request is not null)
        {
            await GridExport.ExportAsync(format, request);
        }
    }

    private GridExportRequest? BuildExportRequest() =>
        GridExportBuilder.FromRows(
            "users",
            "User list",
            new[] { "Email", "Name", "Type", "Roles", "CustomerId", "Status" },
            _result?.Items.Select(item => (IReadOnlyList<string>)new[]
            {
                GridExportBuilder.Cell(item.Email),
                GridExportBuilder.Cell($"{item.FirstName} {item.LastName}"),
                GridExportBuilder.Cell(item.AccountType),
                GridExportBuilder.Cell(FormatRoles(item)),
                GridExportBuilder.Cell(item.CustomerId),
                GridExportBuilder.Cell(item.IsActive ? "Active" : "Locked")
            }));

    private async Task ChangePageAsync(int page)
    {
        if (page < 1) return;
        _filter.Page = page;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        await LoadGridAsync(_cts.Token);
    }
    public async ValueTask DisposeAsync() { _disposed = true; if (_cts is not null) { await _cts.CancelAsync(); _cts.Dispose(); } }
}
