@page "/admin/audit-logs"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOnly)]
@using WebShopABMATIC.Application.Admin.AuditLogs
@using WebShopABMATIC.Application.Audit
@using WebShopABMATIC.Application.Common
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Web.Services
@inject IAuditLogAdminPort AuditPort
@inject IGridExportService GridExport
@implements IAsyncDisposable

<PageTitle>Audit log</PageTitle>

<div class="entity-page">
    <div class="entity-page-header page-header d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1"><i class="bi bi-journal-check text-primary"></i> Audit log</h1>
            <p class="mb-0 text-muted">Track who did what — CRUD, login, logout, and exports.</p>
        </div>
        <button type="button" class="btn btn-success btn-sm" @onclick="RefreshAsync" disabled="@_loading" title="Reload audit entries">
            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
        </button>
    </div>

    <div class="card shadow-sm border audit-filter-card mb-3">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small mb-0">From</label>
                    <input type="date" class="form-control form-control-sm" @bind="_draftFrom" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-0">To</label>
                    <input type="date" class="form-control form-control-sm" @bind="_draftTo" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-0">Action</label>
                    <select class="form-select form-select-sm" @bind="_draftAction">
                        <option value="">All</option>
                        @foreach (var action in AuditActions.All)
                        {
                            <option value="@action">@action</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-0">Severity</label>
                    <select class="form-select form-select-sm" @bind="_draftSeverity">
                        <option value="">All</option>
                        @foreach (var severity in AuditSeverity.All)
                        {
                            <option value="@severity">@severity</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-0">Entity</label>
                    <select class="form-select form-select-sm" @bind="_draftEntity">
                        <option value="">All</option>
                        @foreach (var entity in _entityOptions)
                        {
                            <option value="@entity">@entity</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-0">User</label>
                    <input type="search" class="form-control form-control-sm" placeholder="Email or name…" @bind="_draftUser" />
                </div>
                <div class="col-md-3">
                    <div class="form-check mb-1">
                        <input type="checkbox" class="form-check-input" id="audit-success" @bind="_draftSuccessOnly" />
                        <label class="form-check-label small" for="audit-success">Successful only</label>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="audit-fail" @bind="_draftFailuresOnly" />
                        <label class="form-check-label small" for="audit-fail">Failures only</label>
                    </div>
                </div>
                <div class="col-md-9 d-flex flex-wrap gap-2 align-items-center">
                    <button type="button" class="btn btn-primary" @onclick="ApplyFiltersAsync">
                        <i class="bi bi-funnel-fill me-1"></i>Apply filters
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="ClearFiltersAsync">
                        <i class="bi bi-x-circle-fill me-1"></i>Clear
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => _showLegend = true">
                        <i class="bi bi-info-circle me-1"></i>Badges legend
                    </button>
                    <AdminExportDropdown Disabled="@ExportDisabled" OnExport="ExportGridAsync" />
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border entity-grid-card">
        <div class="card-header bg-white entity-grid-toolbar">
            <h2 class="h6 mb-0 fw-bold">Audit entries</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Date/time</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>User</th>
                        <th>Severity</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Loading…</td></tr>
                    }
                    else if (!string.IsNullOrEmpty(_error))
                    {
                        <tr><td colspan="7" class="text-center text-danger py-4">@_error</td></tr>
                    }
                    else if (_result is null || _result.Items.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No audit entries found.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in _result.Items)
                        {
                            <tr @key="item.Id">
                                <td>@item.Timestamp.ToLocalTime().ToString("g")</td>
                                <td><AuditActionBadge Action="@item.Action" /></td>
                                <td>
                                    <strong>@item.EntityName</strong>
                                    @if (!string.IsNullOrEmpty(item.EntityId))
                                    {
                                        <div class="small text-muted">#@item.EntityId</div>
                                    }
                                </td>
                                <td>@item.UserDisplayName</td>
                                <td>@item.Severity</td>
                                <td class="text-center">
                                    @if (item.Success)
                                    {
                                        <span class="text-success" title="Success"><i class="bi bi-check-circle-fill"></i></span>
                                    }
                                    else
                                    {
                                        <span class="text-danger" title="Failed"><i class="bi bi-x-circle-fill"></i></span>
                                    }
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm btn-primary" title="View details" @onclick="() => OpenDetailAsync(item.Id)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <AdminGridPagination TotalCount="@(_result?.TotalCount ?? 0)" Page="@(_filter.Page)" PageSize="@(_filter.PageSize)" Loading="@_loading" OnPageChanged="ChangePageAsync" />
    </div>
</div>

@if (_showLegend)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Badges legend</h5>
                    <button type="button" class="btn-close" @onclick="() => _showLegend = false"></button>
                </div>
                <div class="modal-body">
                    <div class="audit-legend-list">
                        @foreach (var action in AuditActions.All)
                        {
                            <AuditActionBadge Action="@action" />
                        }
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showLegend = false">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showDetail && _detail is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Audit entry #@_detail.Id</h5>
                    <button type="button" class="btn-close" @onclick="CloseDetail" disabled="@_detailLoading"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-3">
                        <div class="col-md-6"><strong>Date/time:</strong> @_detail.Timestamp.ToLocalTime().ToString("F")</div>
                        <div class="col-md-6"><strong>Action:</strong> <AuditActionBadge Action="@_detail.Action" /></div>
                        <div class="col-md-6"><strong>Entity:</strong> @_detail.EntityName @(string.IsNullOrEmpty(_detail.EntityId) ? "" : $"#{_detail.EntityId}")</div>
                        <div class="col-md-6"><strong>User:</strong> @_detail.UserDisplayName</div>
                        <div class="col-md-6"><strong>Severity:</strong> @_detail.Severity</div>
                        <div class="col-md-6"><strong>Status:</strong> @(_detail.Success ? "Success" : "Failed")</div>
                        @if (!string.IsNullOrEmpty(_detail.IpAddress))
                        {
                            <div class="col-md-6"><strong>IP:</strong> @_detail.IpAddress</div>
                        }
                        @if (_detail.DurationMs is not null)
                        {
                            <div class="col-md-6"><strong>Duration:</strong> @_detail.DurationMs ms</div>
                        }
                        @if (!string.IsNullOrEmpty(_detail.ErrorMessage))
                        {
                            <div class="col-12"><strong>Error:</strong> <span class="text-danger">@_detail.ErrorMessage</span></div>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_detail.OldValues))
                    {
                        <label class="form-label fw-semibold">Previous values</label>
                        <pre class="audit-detail-json">@FormatJson(_detail.OldValues)</pre>
                    }
                    @if (!string.IsNullOrWhiteSpace(_detail.NewValues))
                    {
                        <label class="form-label fw-semibold">New values</label>
                        <pre class="audit-detail-json">@FormatJson(_detail.NewValues)</pre>
                    }
                    @if (!string.IsNullOrWhiteSpace(_detail.AdditionalInfo))
                    {
                        <label class="form-label fw-semibold">Additional info</label>
                        <pre class="audit-detail-json">@FormatJson(_detail.AdditionalInfo)</pre>
                    }
                    @if (!string.IsNullOrWhiteSpace(_detail.UserAgent))
                    {
                        <label class="form-label fw-semibold">User agent</label>
                        <p class="small text-muted mb-0">@_detail.UserAgent</p>
                    }
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" @onclick="CloseDetail">
                        <i class="bi bi-x me-1"></i>Close
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private AuditLogListFilter _filter = new();
    private PagedResult<AuditLogListItemDto>? _result;
    private AuditLogDetailDto? _detail;
    private readonly string[] _entityOptions =
    [
        "ApplicationUser", "Product", "Customer", "Order", "AzureFile",
        "CheckoutStarted", "PaymentPaid", "users", "products", "customers"
    ];

    private DateTime? _draftFrom;
    private DateTime? _draftTo;
    private string _draftAction = "";
    private string _draftSeverity = "";
    private string _draftEntity = "";
    private string _draftUser = "";
    private bool _draftSuccessOnly;
    private bool _draftFailuresOnly;

    private bool _loading = true;
    private bool _detailLoading;
    private bool _showLegend;
    private bool _showDetail;
    private string? _error;
    private CancellationTokenSource? _cts;

    private bool HasNextPage => _result is not null && _result.Page * _result.PageSize < _result.TotalCount;

    protected override async Task OnInitializedAsync() => await LoadGridAsync();

    private async Task LoadGridAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        _loading = true;
        _error = null;
        try
        {
            _result = await AuditPort.GetAuditLogsAsync(_filter, _cts.Token);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _result = null;
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync() => await LoadGridAsync();

    private async Task ApplyFiltersAsync()
    {
        _filter.FromDate = _draftFrom;
        _filter.ToDate = _draftTo;
        _filter.Action = string.IsNullOrWhiteSpace(_draftAction) ? null : _draftAction;
        _filter.Severity = string.IsNullOrWhiteSpace(_draftSeverity) ? null : _draftSeverity;
        _filter.EntityName = string.IsNullOrWhiteSpace(_draftEntity) ? null : _draftEntity;
        _filter.UserSearch = string.IsNullOrWhiteSpace(_draftUser) ? null : _draftUser.Trim();
        _filter.SuccessOnly = _draftSuccessOnly ? true : null;
        _filter.FailuresOnly = _draftFailuresOnly ? true : null;
        _filter.Page = 1;
        await LoadGridAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _draftFrom = null;
        _draftTo = null;
        _draftAction = "";
        _draftSeverity = "";
        _draftEntity = "";
        _draftUser = "";
        _draftSuccessOnly = false;
        _draftFailuresOnly = false;
        _filter = new AuditLogListFilter();
        await LoadGridAsync();
    }

    private async Task ChangePageAsync(int page)
    {
        _filter.Page = Math.Max(1, page);
        await LoadGridAsync();
    }

    private async Task OpenDetailAsync(long id)
    {
        _showDetail = true;
        _detailLoading = true;
        _detail = null;
        try
        {
            _detail = await AuditPort.GetAuditLogDetailAsync(id, _cts?.Token ?? CancellationToken.None);
        }
        finally
        {
            _detailLoading = false;
        }
    }

    private void CloseDetail()
    {
        _showDetail = false;
        _detail = null;
    }

    private static string FormatJson(string? raw)
    {
        if (string.IsNullOrWhiteSpace(raw))
        {
            return "";
        }

        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            return System.Text.Json.JsonSerializer.Serialize(doc, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return raw;
        }
    }

    private bool ExportDisabled => _loading || _result is null || _result.Items.Count == 0;

    private async Task ExportGridAsync(string format)
    {
        var request = BuildExportRequest();
        if (request is not null)
        {
            await GridExport.ExportAsync(format, request);
        }
    }

    private GridExportRequest? BuildExportRequest() =>
        GridExportBuilder.FromRows(
            "audit-log",
            "Audit log",
            new[] { "Date/time", "Action", "Entity", "EntityId", "User", "Severity", "Success" },
            _result?.Items.Select(item => (IReadOnlyList<string>)new[]
            {
                GridExportBuilder.Cell(item.Timestamp.ToLocalTime().ToString("g")),
                GridExportBuilder.Cell(item.Action),
                GridExportBuilder.Cell(item.EntityName),
                GridExportBuilder.Cell(item.EntityId),
                GridExportBuilder.Cell(item.UserDisplayName),
                GridExportBuilder.Cell(item.Severity),
                GridExportBuilder.Cell(item.Success ? "Yes" : "No")
            }));

    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}
