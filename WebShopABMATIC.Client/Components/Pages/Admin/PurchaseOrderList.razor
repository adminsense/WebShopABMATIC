@page "/admin/stock/purchase-orders"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Admin.Stock
@using WebShopABMATIC.Application.Common
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@inject IStockOrderAdminPort AdminPort
@implements IAsyncDisposable

<PageTitle>Purchase orders</PageTitle>

<div class="entity-page">
    <a class="btn btn-secondary btn-back mb-3" href="/admin/hub/stock" data-enhance-nav="false">
        <span class="oi oi-arrow-left"></span> Back to Stock hub
    </a>
    <div class="entity-page-header page-header">
        <h1 class="h3 mb-1"><i class="bi bi-receipt text-primary"></i> Purchase orders</h1>
        <p class="mb-0">Supplier replenishment — header and lines before goods arrive.</p>
    </div>

    <div class="card shadow-sm border entity-form-card admin-form-card">
        <div class="card-header bg-white">
            <h2 class="h6 mb-0 fw-bold">@(_isEditing ? $"Edit PO #{_model.Id}" : "Create purchase order")</h2>
        </div>
        <div class="card-body">
            @if (_formLoading)
            {
                <p class="text-muted mb-0">Loading…</p>
            }
            else
            {
                <EditForm Model="_model" OnValidSubmit="SaveAsync">
                    <DataAnnotationsValidator />
                    <div class="entity-form-fields">
                        <div class="row g-2">
                            <div class="col-md-4">
                                <label class="form-label" for="po-supplier">Supplier *</label>
                                <InputSelect id="po-supplier" class="form-select form-select-sm" @bind-Value="_model.SupplierId">
                                    @foreach (var supplier in _lookups?.Suppliers ?? [])
                                    {
                                        <option value="@supplier.Id">@supplier.Name (@supplier.Id)</option>
                                    }
                                </InputSelect>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="po-order-date">Order date</label>
                                <InputDate id="po-order-date" class="form-control form-control-sm" @bind-Value="_model.OrderDate" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="po-expected">Expected delivery</label>
                                <InputDate id="po-expected" class="form-control form-control-sm" @bind-Value="_model.ExpectedDeliveryDate" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="po-notes">Notes</label>
                                <InputText id="po-notes" class="form-control form-control-sm" @bind-Value="_model.Notes" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="po-internal">Internal notes</label>
                                <InputText id="po-internal" class="form-control form-control-sm" @bind-Value="_model.InternalNotes" />
                            </div>
                            <div class="col-md-3 d-flex align-items-end">
                                <div class="form-check mb-1">
                                    <InputCheckbox class="form-check-input" id="po-completed" @bind-Value="_model.IsCompleted" />
                                    <label class="form-check-label" for="po-completed">Completed</label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h3 class="h6 mb-0 fw-bold">Lines</h3>
                                <button type="button" class="btn btn-sm btn-outline-primary" @onclick="AddLine">
                                    <i class="bi bi-plus-lg"></i> Add line
                                </button>
                            </div>
                            @if (_model.Lines.Count == 0)
                            {
                                <p class="text-muted small mb-0">Add at least one line.</p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Product ID</th>
                                                <th>Product name</th>
                                                <th>Qty ordered</th>
                                                <th>Delivered</th>
                                                <th>Unit price</th>
                                                <th>Line total</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @for (var i = 0; i < _model.Lines.Count; i++)
                                            {
                                                var line = _model.Lines[i];
                                                var index = i;
                                                <tr>
                                                    <td style="width: 110px">
                                                        <InputNumber class="form-control form-control-sm" @bind-Value="line.ProductId" />
                                                    </td>
                                                    <td>
                                                        <InputText class="form-control form-control-sm" @bind-Value="line.ProductName" />
                                                    </td>
                                                    <td style="width: 110px">
                                                        <InputNumber class="form-control form-control-sm" @bind-Value="line.QuantityOrdered" @bind-Value:after="() => RecalculateLine(line)" />
                                                    </td>
                                                    <td style="width: 90px">@line.QuantityDelivered.ToString("N2")</td>
                                                    <td style="width: 110px">
                                                        <InputNumber class="form-control form-control-sm" @bind-Value="line.PurchaseUnitPrice" @bind-Value:after="() => RecalculateLine(line)" />
                                                    </td>
                                                    <td style="width: 100px">@line.PurchaseTotalPrice.ToString("N2")</td>
                                                    <td class="text-end" style="width: 50px">
                                                        <button type="button" class="btn btn-sm btn-outline-danger" title="Remove line" @onclick="() => RemoveLine(index)" disabled="@(line.QuantityDelivered > 0)">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                        <div class="col-12 d-flex flex-wrap gap-2 pt-3">
                            <button type="submit" class="btn btn-primary" disabled="@(_saving || _model.Lines.Count == 0)">
                                @(_saving ? "Saving…" : (_isEditing ? "Update PO" : "Create PO"))
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="CancelForm" disabled="@_saving">Clear</button>
                            @if (_isEditing && !_model.IsCompleted)
                            {
                                <a class="btn btn-outline-primary" href="@($"/admin/stock/purchase-orders/{_model.Id}/receive")" data-enhance-nav="false">
                                    Receive delivery
                                </a>
                            }
                        </div>
                    </div>
                </EditForm>

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@_formError</div>
                }
            }
        </div>
    </div>

    <div class="card shadow-sm border entity-grid-card">
        <div class="card-header bg-white entity-grid-toolbar d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h2 class="h6 mb-0 fw-bold">Purchase order list</h2>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <div class="form-check mb-0">
                    <input class="form-check-input" type="checkbox" id="po-open-only" checked="@_openOnly" @onchange="ToggleOpenOnlyAsync" />
                    <label class="form-check-label small" for="po-open-only">Open only</label>
                </div>
                <AdminGridSearch @bind-Value="_searchDraft" OnSearch="ApplySearchAsync" />
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>PO #</th>
                        <th>Supplier</th>
                        <th>Created</th>
                        <th>Expected</th>
                        <th>Lines</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">Loading…</td></tr>
                    }
                    else if (!string.IsNullOrEmpty(_gridError))
                    {
                        <tr><td colspan="8" class="text-center text-danger py-4">@_gridError</td></tr>
                    }
                    else if (_result is null || _result.Items.Count == 0)
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">No purchase orders found.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in _result.Items)
                        {
                            <tr @key="item.Id" class="@(_model.Id == item.Id ? "table-active" : null)">
                                <td>@item.Id</td>
                                <td>@item.SupplierName</td>
                                <td>@item.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>@(item.ExpectedDeliveryDate?.ToString("yyyy-MM-dd") ?? "—")</td>
                                <td>@item.LinesFullyDelivered / @item.LineCount</td>
                                <td>@(item.TotalAmount?.ToString("N2") ?? "—")</td>
                                <td>
                                    @if (item.IsCompleted)
                                    {
                                        <span class="badge text-bg-success">Completed</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-warning">Open</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a class="btn btn-sm btn-primary" href="@($"/admin/stock/purchase-orders?edit={item.Id}")" data-enhance-nav="false" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (!item.IsCompleted)
                                        {
                                            <a class="btn btn-sm btn-outline-primary" href="@($"/admin/stock/purchase-orders/{item.Id}/receive")" data-enhance-nav="false" title="Receive">
                                                <i class="bi bi-box-arrow-in-down"></i>
                                            </a>
                                        }
                                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => PromptDelete(item)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <AdminGridPagination TotalCount="@(_result?.TotalCount ?? 0)" Page="@(_filter.Page)" PageSize="@(_filter.PageSize)" Loading="@_loading" OnPageChanged="ChangePageAsync" />
    </div>
</div>

@if (_showDeleteConfirm && _itemToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Confirm deletion</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete" disabled="@_deleting"></button>
                </div>
                <div class="modal-body"><p class="mb-0">Delete purchase order <strong>#@_itemToDelete.Id</strong>?</p></div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-secondary" @onclick="CancelDelete" disabled="@_deleting">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteAsync" disabled="@_deleting">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [SupplyParameterFromQuery(Name = "edit")]
    public int? EditId { get; set; }

    private CancellationTokenSource? _cts;
    private StockOrderListFilter _filter = new() { OpenOnly = true };
    private StockOrderEditDto _model = new() { SupplierId = 1, Lines = [new StockOrderLineEditDto()] };
    private StockOrderLookupsDto? _lookups;
    private string _searchDraft = string.Empty;
    private bool _openOnly = true;
    private bool _loading = true;
    private bool _formLoading;
    private bool _saving;
    private bool _deleting;
    private bool _showDeleteConfirm;
    private bool _initialized;
    private string? _formError;
    private string? _gridError;
    private PagedResult<StockOrderSummaryDto>? _result;
    private StockOrderSummaryDto? _itemToDelete;
    private bool _isEditing => _model.Id > 0;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadLookupsAsync(_cts.Token);
        await LoadGridAsync(_cts.Token);
        if (EditId is > 0)
        {
            await EditAsync(EditId.Value);
        }

        _initialized = true;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized || EditId is not > 0 || _model.Id == EditId)
        {
            return;
        }

        await EditAsync(EditId.Value);
    }

    private async Task LoadLookupsAsync(CancellationToken ct)
    {
        try
        {
            _lookups = await AdminPort.GetLookupsAsync(ct);
            if (_lookups.Suppliers.Count > 0 && !_lookups.Suppliers.Any(s => s.Id == _model.SupplierId))
            {
                _model.SupplierId = _lookups.Suppliers[0].Id;
            }
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
    }

    private async Task LoadGridAsync(CancellationToken ct)
    {
        _loading = true;
        _gridError = null;
        try
        {
            _result = await AdminPort.GetOrdersAsync(_filter, ct);
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (Exception ex)
        {
            _result = null;
            _gridError = ex.Message;
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplySearchAsync()
    {
        _filter.Search = _searchDraft;
        _filter.Page = 1;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        await LoadGridAsync(_cts.Token);
    }

    private async Task ToggleOpenOnlyAsync(ChangeEventArgs args)
    {
        _openOnly = args.Value is true;
        _filter.OpenOnly = _openOnly;
        _filter.Page = 1;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        await LoadGridAsync(_cts.Token);
    }

    private async Task EditAsync(int id)
    {
        _formLoading = true;
        _formError = null;
        try
        {
            var item = await AdminPort.GetForEditAsync(id, _cts?.Token ?? CancellationToken.None);
            if (item is null)
            {
                _formError = "Purchase order not found.";
                return;
            }

            _model = item;
            if (_model.Lines.Count == 0)
            {
                _model.Lines.Add(new StockOrderLineEditDto());
            }
        }
        finally
        {
            _formLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        _saving = true;
        _formError = null;
        try
        {
            foreach (var line in _model.Lines)
            {
                RecalculateLine(line);
            }

            var id = await AdminPort.SaveAsync(_model, _cts?.Token ?? CancellationToken.None);
            await LoadGridAsync(_cts?.Token ?? CancellationToken.None);
            await EditAsync(id);
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void CancelForm()
    {
        _formError = null;
        _model = new StockOrderEditDto
        {
            SupplierId = _lookups?.Suppliers.FirstOrDefault()?.Id ?? 1,
            Lines = [new StockOrderLineEditDto()]
        };
    }

    private void AddLine() => _model.Lines.Add(new StockOrderLineEditDto { QuantityOrdered = 1 });

    private void RemoveLine(int index)
    {
        if (index >= 0 && index < _model.Lines.Count)
        {
            _model.Lines.RemoveAt(index);
        }
    }

    private static void RecalculateLine(StockOrderLineEditDto line) =>
        line.PurchaseTotalPrice = line.QuantityOrdered * line.PurchaseUnitPrice;

    private void PromptDelete(StockOrderSummaryDto item)
    {
        _itemToDelete = item;
        _showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        _showDeleteConfirm = false;
        _itemToDelete = null;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_itemToDelete is null)
        {
            return;
        }

        _deleting = true;
        try
        {
            await AdminPort.DeleteAsync(_itemToDelete.Id, _cts?.Token ?? CancellationToken.None);
            if (_model.Id == _itemToDelete.Id)
            {
                CancelForm();
            }

            CancelDelete();
            await LoadGridAsync(_cts?.Token ?? CancellationToken.None);
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _deleting = false;
        }
    }

    private async Task ChangePageAsync(int page)
    {
        if (page < 1)
        {
            return;
        }

        _filter.Page = page;
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        await LoadGridAsync(_cts.Token);
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}
