@page "/orders/{OrderId:int}/confirmation"
@layout StoreLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Ports.Outbound
@using WebShopABMATIC.Application.Store.Checkout
@attribute [Authorize(Policy = AppPolicies.CustomerOnly)]
@inject ICheckoutPort CheckoutPort
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Order confirmation</PageTitle>

@* Same chrome as catalog/cart/orders: StoreLayout = header + category sidebar + main *@
<div class="container payment-confirmation-page">
    @if (_loading)
    {
        <p class="payment-confirmation-state">Loading…</p>
    }
    else if (_order is null)
    {
        <div class="payment-confirmation-state">
            <p>Order not found.</p>
            <NavLink href="/orders" class="btn btn-primary">My orders</NavLink>
        </div>
    }
    else
    {
        <section class="payment-success-hero">
            <div class="payment-success-icon" aria-hidden="true">✓</div>
            <h1 class="page-title">@(_order.IsPaid ? "Payment received" : "Order received")</h1>
            <p>
                @if (_order.IsPaid)
                {
                    <text>Thank you — your payment was received. Your order is confirmed and stock will be updated.</text>
                }
                else
                {
                    <text>Your order was received. Payment status is shown below.</text>
                }
            </p>
        </section>

        <h2 class="payment-confirmation-title">Order confirmation</h2>

        <section class="payment-confirmation-card">
            <p class="payment-order-number"><strong>Order #@(_order.OrderNumber ?? _order.OrderId)</strong></p>
            <p class="payment-order-date">@_order.CreatedAt.ToLocalTime().ToString("f")</p>
            <p class="payment-status-line">
                Payment:
                @if (_order.IsPaid)
                {
                    <span class="payment-status-badge payment-status-badge--paid">@_order.PaymentStatus</span>
                }
                else
                {
                    <span class="payment-status-badge payment-status-badge--pending">@_order.PaymentStatus</span>
                }
            </p>

            <div class="payment-summary-lines">
            @foreach (var line in ProductLines)
            {
                <div class="payment-summary-line">
                    <span>@line.Name × @line.Quantity</span>
                    <span>@FormatPrice(line.LineTotal)</span>
                </div>
            }

                <div class="payment-summary-line">
                    <span>@DeliveryLabel</span>
                    <span>@FormatPrice(DeliveryFee)</span>
                </div>
                <div class="payment-summary-line">
                    <span>VAT</span>
                    <span>@FormatPrice(_order.VatAmount)</span>
                </div>
            </div>

            <div class="payment-summary-line payment-summary-total">
                <span>Total (incl. VAT)</span>
                <span>@FormatPrice(_order.TotalInclVat)</span>
            </div>

            <NavLink href="/" class="btn btn-primary payment-continue-button">Continue shopping</NavLink>
        </section>
    }
</div>

@code {
    [Parameter] public int OrderId { get; set; }

    private CheckoutOrderSummaryDto? _order;
    private bool _loading = true;
    private IEnumerable<CheckoutLineQuoteDto> ProductLines =>
        _order?.Lines.Where(line => !line.IsDelivery) ?? [];
    private IEnumerable<CheckoutLineQuoteDto> DeliveryLines =>
        _order?.Lines.Where(line => line.IsDelivery) ?? [];
    private decimal DeliveryFee => DeliveryLines.Sum(line => line.LineTotal);
    private string DeliveryLabel =>
        DeliveryLines.Select(line => line.Name).FirstOrDefault(name => !string.IsNullOrWhiteSpace(name))
        ?? "Delivery";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _order = await CheckoutPort.GetOrderSummaryAsync(OrderId, new StoreUserLookup
        {
            Email = auth.User.Identity?.Name,
            CustomerId = int.TryParse(auth.User.FindFirstValue(LegacyAuthClaims.CustomerId), out var cid) ? cid : null
        });
        _loading = false;
    }

    private static string FormatPrice(decimal price) => $"€{price:F2}";
}
