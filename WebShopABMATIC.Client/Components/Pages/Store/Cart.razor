@page "/cart"
@layout StoreLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Ports.Outbound
@using WebShopABMATIC.Application.Store.Checkout
@inject StoreCartService CartService
@inject ICheckoutPort CheckoutPort
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Cart</PageTitle>

<div class="container">
    <h1 class="page-title">Your cart</h1>

    @if (!_cartReady)
    {
        <p style="color:var(--muted);margin-bottom:1.5rem">Loading cart…</p>
    }
    else if (CartService.Lines.Count == 0)
    {
        <p style="color:var(--muted);margin-bottom:1.5rem">Your cart is empty.</p>
        <NavLink href="/" class="btn btn-primary">Continue shopping</NavLink>
    }
    else
    {
        @if (!CartService.IsCustomerCart)
        {
            <div class="alert alert-info mb-3" role="status">
                <strong>Your cart is ready.</strong>
                Sign in or create an account to place the order and pay.
                You can keep shopping, change quantities, or remove lines first.
                <div class="mt-2 d-flex flex-wrap gap-2">
                    <NavLink href="/sign-in?returnUrl=/cart" class="btn btn-primary" data-enhance-nav="false">Sign in to checkout</NavLink>
                    <NavLink href="/sign-up?returnUrl=/cart" class="btn btn-outline" data-enhance-nav="false">Create account</NavLink>
                </div>
            </div>
        }
        <div class="cart-layout">
            <div class="cart-table">
                @foreach (var line in CartService.Lines)
                {
                    var stockIssue = GetLineStockIssue(line.ProductId, line.Quantity);
                    <div class="cart-row @(stockIssue is not null ? "cart-row--stock-issue" : null)" @key="line.Id">
                        <StoreProductImage Src="@StoreCartService.ProductImageUrl(line.ProductId)" Alt="@line.Name" />
                        <div>
                            <h4>@line.Name</h4>
                            @if (line.HasOptions)
                            {
                                <p class="cart-line-options">@line.OptionsSummary</p>
                            }
                            <p class="unit">@FormatPrice(line.UnitPrice) each</p>
                            @if (stockIssue is not null)
                            {
                                <p class="cart-line-stock-issue">
                                    <span class="cart-stock-badge">@stockIssue.Badge</span>
                                    @stockIssue.Hint
                                    <button type="button" class="cart-stock-remove-link" @onclick="() => RemoveLineAsync(line.Id)">Remove</button>
                                </p>
                            }
                        </div>
                        <div class="qty-control">
                            <button type="button" @onclick="() => ChangeQuantityAsync(line.Id, line.Quantity - 1)">−</button>
                            <span>@line.Quantity</span>
                            <button type="button"
                                    disabled="@(stockIssue?.Available is int max && line.Quantity >= max)"
                                    @onclick="() => ChangeQuantityAsync(line.Id, line.Quantity + 1)">+</button>
                        </div>
                        <span class="line-total">@FormatPrice(line.LineTotal)</span>
                        <button type="button" class="remove-btn" title="Remove" @onclick="() => RemoveLineAsync(line.Id)">×</button>
                    </div>
                }
            </div>
            <aside class="summary-card">
                <h3>Order summary</h3>
                @if (_quote is not null)
                {
                    <div class="summary-line"><span>Subtotal (@CartService.ItemCount items)</span><span>@FormatPrice(_quote.Subtotal)</span></div>
                    <div class="summary-line"><span>Delivery</span><span>@DeliverySummaryLabel</span></div>
                    <div class="summary-line"><span>VAT 21%</span><span>@FormatPrice(_quote.VatAmount)</span></div>
                    <div class="summary-line total"><span>Total</span><span>@FormatPrice(_quote.Total)</span></div>
                }
                else
                {
                    <div class="summary-line"><span>Subtotal (@CartService.ItemCount items)</span><span>@FormatPrice(CartService.Subtotal)</span></div>
                    <div class="summary-line"><span>Delivery</span><span>@FormatPrice(0m)</span></div>
                    <div class="summary-line"><span>VAT 21%</span><span>@FormatPrice(CartService.VatAmount)</span></div>
                    <div class="summary-line total"><span>Total</span><span>@FormatPrice(CartService.Total)</span></div>
                }

                @if (!CartService.IsCustomerCart)
                {
                    <p class="store-field-hint mt-2 mb-0">Guest cart is held in this browser session only. Closing the browser clears it — no order is created and no ERP stock is reserved until you place and pay.</p>
                    <NavLink href="/sign-in?returnUrl=/cart" class="btn btn-primary mt-3" data-enhance-nav="false">Sign in to place order</NavLink>
                }
                else
                {
                @if (!string.IsNullOrEmpty(_checkoutError))
                {
                    <div class="alert alert-danger mt-2 mb-0 small">@_checkoutError</div>
                }
                @if (HasBlockingQuoteErrors)
                {
                    <div class="alert alert-danger mt-2 mb-0 small cart-checkout-blocked" role="alert">
                        <strong>Cannot place order.</strong>
                        <span> Fix or remove lines that exceed available stock.</span>
                        @foreach (var err in _quote!.Errors)
                        {
                            <div>@err</div>
                        }
                    </div>
                }

                @if (_options is not null)
                {
                    <div class="form-group" style="margin-top:1rem">
                        <label for="cart-delivery-address">Delivery address</label>
                        @if (_options.DeliveryAddresses.Count == 0)
                        {
                            <p class="store-field-hint mb-0">No delivery address found. <NavLink href="/my-account">Add one in My account</NavLink>.</p>
                        }
                        else
                        {
                            <div class="store-select-wrap">
                                <select id="cart-delivery-address"
                                        class="form-control store-select"
                                        value="@_deliveryAddressId"
                                        @onchange="OnDeliveryAddressChanged">
                                    @foreach (var addr in _options.DeliveryAddresses)
                                    {
                                        <option value="@addr.Id">@addr.Label</option>
                                    }
                                </select>
                            </div>
                        }
                    </div>
                    <div class="form-group" style="margin-top:0.75rem">
                        <label for="cart-freight-option">Delivery / freight</label>
                        @if (!string.IsNullOrWhiteSpace(_options.DeliveryTypeName))
                        {
                            <p class="store-field-hint mb-1">Account type: <strong>@_options.DeliveryTypeName</strong></p>
                        }
                        <div class="store-select-wrap">
                            <select id="cart-freight-option"
                                    class="form-control store-select"
                                    value="@(_deliveryProductId?.ToString() ?? "0")"
                                    @onchange="OnFreightChangedAsync">
                                <option value="0">No delivery charge (€0.00)</option>
                                @foreach (var freight in _options.FreightOptions)
                                {
                                    <option value="@freight.ProductId">@freight.Name — @FormatPrice(freight.UnitPrice)</option>
                                }
                            </select>
                        </div>
                        @if (_options.FreightOptions.Count == 0)
                        {
                            <p class="store-field-hint">No freight products linked for this delivery type in ERP — fee stays €0 until admin maps prices.</p>
                        }
                    </div>
                    <div class="form-group" style="margin-top:0.75rem">
                        <label for="cart-payment-method">Payment method</label>
                        <div class="store-select-wrap">
                            <select id="cart-payment-method"
                                    class="form-control store-select"
                                    value="@_paymentMethodId"
                                    @onchange="OnPaymentMethodChanged">
                                @foreach (var pm in _options.PaymentMethods)
                                {
                                    <option value="@pm.Id" disabled="@(!pm.IsSelectable)">
                                        @pm.Name@(pm.IsSelectable ? "" : " (unavailable online)")
                                    </option>
                                }
                            </select>
                        </div>
                        <p class="store-field-hint">Choose <strong>iDEAL / card (Mollie)</strong> to pay online. Other methods are for ERP/admin only.</p>
                    </div>
                }
                else if (string.IsNullOrEmpty(_checkoutError))
                {
                    <p class="store-field-hint mt-2">Loading checkout options…</p>
                }

                <button type="button"
                        class="btn btn-primary @(HasBlockingQuoteErrors ? "btn-checkout-blocked" : null)"
                        disabled="@(_placing || HasBlockingQuoteErrors)"
                        @onclick="PlaceOrderAsync">
                    @CheckoutButtonLabel
                </button>
                }
            </aside>
        </div>
    }
</div>

@code {
    private CheckoutOptionsDto? _options;
    private CheckoutQuoteDto? _quote;
    private int _deliveryAddressId;
    private int _paymentMethodId = 1;
    private int? _deliveryProductId;
    private string? _checkoutError;
    private bool _placing;
    private bool _cartReady;
    private string? _userEmail;
    private int? _customerId;

    private bool HasBlockingQuoteErrors => _quote?.Errors.Count > 0;

    private string DeliverySummaryLabel
    {
        get
        {
            if (_quote is null)
            {
                return FormatPrice(0m);
            }

            var label = string.IsNullOrWhiteSpace(_quote.DeliveryLabel) ? "Delivery" : _quote.DeliveryLabel;
            return $"{Truncate(label, 42)} — {FormatPrice(_quote.DeliveryFee)}";
        }
    }

    private string CheckoutButtonLabel =>
        _placing
            ? "Processing…"
            : HasBlockingQuoteErrors
                ? "Cannot place order — fix stock or options"
                : "Place order & pay";

    private sealed record LineStockIssue(string Badge, string Hint, int Available);

    protected override void OnInitialized() => CartService.Changed += OnCartChanged;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userEmail = auth.User.Identity?.Name
            ?? auth.User.FindFirstValue(ClaimTypes.Email)
            ?? auth.User.FindFirstValue(LegacyAuthClaims.Login);
        if (auth.User.Identity?.IsAuthenticated == true
            && auth.User.IsInRole(AppRoles.Customer)
            && int.TryParse(auth.User.FindFirstValue(LegacyAuthClaims.CustomerId), out var customerId)
            && customerId > 0)
        {
            _customerId = customerId;
        }

        await CartService.BindToCustomerAsync(_customerId);
        _cartReady = true;

        if (!CartService.IsCustomerCart)
        {
            return;
        }

        await LoadCheckoutOptionsAsync();
        await RefreshQuoteAsync();
    }

    private async Task LoadCheckoutOptionsAsync()
    {
        try
        {
            _options = await CheckoutPort.GetOptionsAsync(UserLookup());
            if (_options is null)
            {
                _checkoutError = "Could not load delivery address and payment options. Refresh the page or sign in again.";
                return;
            }

            if (_options.DeliveryAddresses.Count == 0)
            {
                _checkoutError = "No delivery address on your account. Add one under My account before placing an order.";
            }

            if (_options.DeliveryAddresses.Count > 0)
            {
                _deliveryAddressId = _options.DeliveryAddresses[0].Id;
            }

            if (_options.PaymentMethods.Count > 0)
            {
                _paymentMethodId = _options.PaymentMethods.FirstOrDefault(p => p.IsSelectable)?.Id
                    ?? _options.PaymentMethods.FirstOrDefault(p => p.IsPrePay)?.Id
                    ?? _options.PaymentMethods[0].Id;
            }
        }
        catch (Exception ex)
        {
            _options = null;
            _checkoutError = $"Could not load checkout options: {ex.GetBaseException().Message}";
        }
    }

    private async void OnCartChanged()
    {
        await RefreshQuoteAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshQuoteAsync()
    {
        if ((_customerId is null or <= 0) && string.IsNullOrEmpty(_userEmail))
        {
            _quote = null;
            return;
        }

        if (CartService.Lines.Count == 0)
        {
            _quote = null;
            return;
        }

        _quote = await CheckoutPort.BuildQuoteAsync(new CheckoutQuoteRequest
        {
            UserEmail = _userEmail ?? "",
            DeliveryProductId = _deliveryProductId,
            Lines = CartService.Lines.Select(l => new CheckoutLineRequest
            {
                ProductId = l.ProductId,
                Quantity = l.Quantity,
                Options = l.Options.Select(o => new CheckoutLineOption
                {
                    ProductOptionId = o.OptionId,
                    ProductOptionValueId = o.ValueId,
                    OptionName = o.OptionName,
                    ValueText = o.ValueText
                }).ToList()
            }).ToList()
        });
    }

    private async Task PlaceOrderAsync()
    {
        _checkoutError = null;
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/sign-in?returnUrl=/cart", forceLoad: true);
            return;
        }

        var email = auth.User.Identity?.Name ?? "";
        if (CartService.Lines.Count == 0)
        {
            return;
        }

        _placing = true;
        try
        {
            await RefreshQuoteAsync();
            if (HasBlockingQuoteErrors)
            {
                _checkoutError = null;
                return;
            }

            EnsureCheckoutSelections();
            if (_options is null)
            {
                await LoadCheckoutOptionsAsync();
                EnsureCheckoutSelections();
            }

            if (_options is null)
            {
                _checkoutError ??= "Could not load delivery address and payment options.";
                return;
            }

            if (_deliveryAddressId <= 0)
            {
                _checkoutError = _options.DeliveryAddresses.Count == 0
                    ? "No delivery address on your account. Add one under My account before placing an order."
                    : "Select a delivery address before placing the order.";
                return;
            }

            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var result = await CheckoutPort.PlaceOrderAsync(new CheckoutRequest
            {
                Lines = CartService.Lines.Select(l => new CheckoutLineRequest
                {
                    ProductId = l.ProductId,
                    Quantity = l.Quantity,
                    Options = l.Options.Select(o => new CheckoutLineOption
                    {
                        ProductOptionId = o.OptionId,
                        ProductOptionValueId = o.ValueId,
                        OptionName = o.OptionName,
                        ValueText = o.ValueText
                    }).ToList()
                }).ToList(),
                DeliveryAddressId = _deliveryAddressId,
                PaymentMethodId = _paymentMethodId,
                DeliveryProductId = _deliveryProductId,
                RedirectBaseUrl = baseUrl,
                WebhookBaseUrl = baseUrl
            }, UserLookup());

            if (!result.Success)
            {
                _checkoutError = string.Join(" ", result.Errors);
                await RefreshQuoteAsync();
                return;
            }

            await CartService.ClearAsync();

            if (!string.IsNullOrEmpty(result.RedirectUrl))
            {
                Navigation.NavigateTo(result.RedirectUrl, forceLoad: true);
            }
            else if (!string.IsNullOrEmpty(result.ConfirmationUrl))
            {
                Navigation.NavigateTo(result.ConfirmationUrl, forceLoad: true);
            }
            else
            {
                Navigation.NavigateTo("/orders", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            _checkoutError = $"Checkout failed: {ex.GetBaseException().Message}";
            await RefreshQuoteAsync();
        }
        finally
        {
            _placing = false;
        }
    }

    private void OnDeliveryAddressChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _deliveryAddressId = id;
        }
    }

    private async Task OnFreightChangedAsync(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id) && id > 0)
        {
            _deliveryProductId = id;
        }
        else
        {
            _deliveryProductId = null;
        }

        await RefreshQuoteAsync();
    }

    private void OnPaymentMethodChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var id))
        {
            _paymentMethodId = id;
        }
    }

    private void EnsureCheckoutSelections()
    {
        if (_options is null)
        {
            return;
        }

        if (_deliveryAddressId <= 0 && _options.DeliveryAddresses.Count > 0)
        {
            _deliveryAddressId = _options.DeliveryAddresses[0].Id;
        }

        if (_paymentMethodId <= 0 && _options.PaymentMethods.Count > 0)
        {
            _paymentMethodId = _options.PaymentMethods.FirstOrDefault(p => p.IsSelectable)?.Id
                ?? _options.PaymentMethods.FirstOrDefault(p => p.IsPrePay)?.Id
                ?? _options.PaymentMethods[0].Id;
        }

        if (_options.DeliveryAddresses.All(a => a.Id != _deliveryAddressId)
            && _options.DeliveryAddresses.Count > 0)
        {
            _deliveryAddressId = _options.DeliveryAddresses[0].Id;
        }

        var selectedPm = _options.PaymentMethods.FirstOrDefault(p => p.Id == _paymentMethodId);
        if (selectedPm is null || !selectedPm.IsSelectable)
        {
            var mollie = _options.PaymentMethods.FirstOrDefault(p => p.IsSelectable);
            if (mollie is not null)
            {
                _paymentMethodId = mollie.Id;
            }
        }
    }

    private StoreUserLookup UserLookup() => new()
    {
        Email = _userEmail,
        CustomerId = _customerId
    };

    private Task ChangeQuantityAsync(string lineId, int quantity) =>
        CartService.SetQuantityAsync(lineId, quantity);

    private Task RemoveLineAsync(string lineId) =>
        CartService.RemoveAsync(lineId);

    private LineStockIssue? GetLineStockIssue(int productId, int quantity)
    {
        var quoteLine = _quote?.Lines.FirstOrDefault(l => l.ProductId == productId);
        if (quoteLine is null)
        {
            return null;
        }

        if (quantity <= quoteLine.AvailableStock)
        {
            return null;
        }

        if (quoteLine.AvailableStock <= 0)
        {
            return new LineStockIssue(
                StorePriceFormatter.OutOfStockLabel,
                "Another order may have taken the last units. Remove this line to continue.",
                0);
        }

        return new LineStockIssue(
            $"Only {quoteLine.AvailableStock} left",
            $"Reduce quantity to {quoteLine.AvailableStock} or remove this line.",
            quoteLine.AvailableStock);
    }

    private static string Truncate(string value, int max) =>
        value.Length <= max ? value : value[..(max - 1)] + "…";

    private static string FormatPrice(decimal price) => $"€{price:F2}";
}
