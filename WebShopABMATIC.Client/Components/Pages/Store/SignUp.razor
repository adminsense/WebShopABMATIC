@page "/sign-up"
@layout StoreLayout

@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Ports.Outbound
@using WebShopABMATIC.Application.Store.Registration
@using WebShopABMATIC.Infrastructure.Auth
@using WebShopABMATIC.Web.Components.Account.Shared
@using WebShopABMATIC.Web.Forms

@inject ICustomerRegistrationPort RegistrationPort
@inject ILegacySignInPort LegacySignIn
@inject NavigationManager Navigation

<PageTitle>Create account</PageTitle>

<div class="auth-wrap">
    <div class="auth-card" style="max-width:640px">
        <h1>Create account</h1>
        <p>Register as an individual customer to shop online. You will always have the <strong>Customer</strong> role; only an administrator can change that later.</p>

        <StatusMessage Message="@_errorMessage" />

        <EditForm Model="_input" method="post" OnValidSubmit="RegisterAsync" FormName="store-signup">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger mb-3" role="alert" />
            <div class="form-group">
                <label for="signup-email">Email *</label>
                <InputText id="signup-email" @bind-Value="_input.Email" autocomplete="username" />
                <ValidationMessage For="() => _input.Email" />
            </div>
            <div class="form-group">
                <label for="signup-firstname">First name *</label>
                <InputText id="signup-firstname" @bind-Value="_input.FirstName" autocomplete="given-name" />
                <ValidationMessage For="() => _input.FirstName" />
            </div>
            <div class="form-group">
                <label for="signup-lastname">Last name *</label>
                <InputText id="signup-lastname" @bind-Value="_input.LastName" autocomplete="family-name" />
                <ValidationMessage For="() => _input.LastName" />
            </div>
            <div class="form-group">
                <label for="signup-phone">Phone *</label>
                <InputText id="signup-phone" @bind-Value="_input.Phone" autocomplete="tel" />
                <ValidationMessage For="() => _input.Phone" />
            </div>
            <div class="form-group">
                <label for="signup-street">Street *</label>
                <InputText id="signup-street" @bind-Value="_input.Street" autocomplete="street-address" />
                <ValidationMessage For="() => _input.Street" />
            </div>
            <div class="row g-2">
                <div class="col-4 form-group">
                    <label for="signup-number">House no. *</label>
                    <InputText id="signup-number" @bind-Value="_input.HouseNumber" />
                    <ValidationMessage For="() => _input.HouseNumber" />
                </div>
                <div class="col-4 form-group">
                    <label for="signup-box">Box</label>
                    <InputText id="signup-box" @bind-Value="_input.Box" />
                </div>
                <div class="col-4 form-group">
                    <label for="signup-postal">Postal code *</label>
                    <InputText id="signup-postal" @bind-Value="_input.PostalCode" autocomplete="postal-code" />
                    <ValidationMessage For="() => _input.PostalCode" />
                </div>
            </div>
            <div class="form-group">
                <label for="signup-city">City *</label>
                <InputText id="signup-city" @bind-Value="_input.CityName" autocomplete="address-level2" />
                <ValidationMessage For="() => _input.CityName" />
            </div>
            <div class="form-group">
                <label for="signup-password">Password *</label>
                <InputText id="signup-password" type="password" @bind-Value="_input.Password" autocomplete="new-password" />
                <ValidationMessage For="() => _input.Password" />
            </div>
            <div class="form-group">
                <label for="signup-confirm">Confirm password *</label>
                <InputText id="signup-confirm" type="password" @bind-Value="_input.ConfirmPassword" autocomplete="new-password" />
                <ValidationMessage For="() => _input.ConfirmPassword" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@_submitting">@(_submitting ? "Creating account…" : "Create account")</button>
        </EditForm>

        <p class="mt-3 mb-0" style="font-size:0.85rem;color:var(--muted)">
            Already have an account? <NavLink href="/sign-in">Sign in</NavLink>
            · <NavLink href="/">← Back to catalog</NavLink>
        </p>
    </div>
</div>

@code {
    private string? _errorMessage;
    private bool _submitting;

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [SupplyParameterFromForm]
    private StoreSignUpFormModel _input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private async Task RegisterAsync()
    {
        _submitting = true;
        _errorMessage = null;

        try
        {
            var result = await RegistrationPort.RegisterAsync(new CustomerRegistrationRequest
            {
                Email = _input.Email,
                Password = _input.Password,
                FirstName = _input.FirstName,
                LastName = _input.LastName,
                Phone = _input.Phone,
                Street = _input.Street,
                HouseNumber = _input.HouseNumber,
                Box = _input.Box,
                PostalCode = _input.PostalCode,
                CityName = _input.CityName
            });

            if (!result.Succeeded)
            {
                _errorMessage = string.Join(" ", result.Errors);
                return;
            }

            if (HttpContext is null)
            {
                Navigation.NavigateTo("/sign-in", forceLoad: true);
                return;
            }

            var signIn = await LegacySignIn.SignInCustomerAsync(_input.Email, _input.Password);
            if (!signIn.Succeeded || signIn.Principal is null)
            {
                Navigation.NavigateTo("/sign-in", forceLoad: true);
                return;
            }

            await LegacyCookieAuthentication.SignInAsync(HttpContext, signIn.Principal, isPersistent: false);
            var destination = string.IsNullOrWhiteSpace(ReturnUrl) ? "/" : ReturnUrl;
            Navigation.NavigateTo(destination, forceLoad: true);
        }
        finally
        {
            _submitting = false;
        }
    }
}
