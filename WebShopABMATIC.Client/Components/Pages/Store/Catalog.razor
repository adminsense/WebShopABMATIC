@page "/"
@layout StoreLayout
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Store
@inject IStoreCatalogPort CatalogPort
@inject NavigationManager Navigation

<PageTitle>WebShop — Catalog</PageTitle>

<div class="store-content-inner">
    @if (_showNewProducts)
    {
        <section class="store-section">
            <h2 class="store-section-title">New products</h2>
            @if (_newProducts.Count == 0 && !_loading)
            {
                <p class="text-muted">No new products at the moment.</p>
            }
            else
            {
                <div class="product-grid">
                    @foreach (var p in _newProducts)
                    {
                        <ProductCard Product="p" OnSelect="GoToProduct" />
                    }
                </div>
            }
        </section>
    }

    <section class="store-section" id="products">
        <h2 class="store-section-title">@_productsTitle</h2>
        @if (_loading)
        {
            <p class="text-muted">Loading catalog…</p>
        }
        else if (_products.Count == 0)
        {
            <p class="text-muted">No products available@(string.IsNullOrWhiteSpace(_search) ? "" : " for this search").</p>
        }
        else
        {
            <div class="product-grid">
                @foreach (var p in _products)
                {
                    <ProductCard Product="p" OnSelect="GoToProduct" />
                }
            </div>
        }
    </section>
</div>

@code {
    private const int HomePageProductLimit = 12;
    private const int NewProductsLimit = 12;

    private int? _selectedCategoryId;
    private string? _search;
    private bool _loading = true;
    private bool _showNewProducts;
    private string _productsTitle = "Products";
    private IReadOnlyList<StoreProduct> _newProducts = [];
    private IReadOnlyList<StoreProduct> _products = [];

    [SupplyParameterFromQuery(Name = "categoryId")]
    public int? CategoryId { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    public string? SearchQuery { get; set; }

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _selectedCategoryId = CategoryId;
        _search = SearchQuery?.Trim();

        _showNewProducts = _selectedCategoryId is null && string.IsNullOrWhiteSpace(_search);
        _productsTitle = _selectedCategoryId is null && string.IsNullOrWhiteSpace(_search)
            ? "Products"
            : string.IsNullOrWhiteSpace(_search)
                ? "Products in category"
                : $"Search results for “{_search}”";

        try
        {
            if (_showNewProducts)
            {
                var newest = await CatalogPort.GetNewProductsAsync(NewProductsLimit);
                _newProducts = newest.Select(StoreProductMapper.ToModel).ToList();
            }
            else
            {
                _newProducts = [];
            }

            var take = _showNewProducts ? (int?)HomePageProductLimit : null;
            var items = await CatalogPort.GetCatalogAsync(take, _selectedCategoryId);
            var mapped = items.Select(StoreProductMapper.ToModel).ToList();

            if (!string.IsNullOrWhiteSpace(_search))
            {
                mapped = mapped
                    .Where(p => p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                                || p.Description.Contains(_search, StringComparison.OrdinalIgnoreCase))
                    .ToList();
            }

            _products = mapped;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoToProduct(int id) => Navigation.NavigateTo($"/product/{id}");
}
