@page "/product/{ProductId:int}"
@layout StoreLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Store
@using WebShopABMATIC.Web.Services
@inject IStoreCatalogPort CatalogPort
@inject StoreCartService Cart
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@(_product?.Name ?? "Product")</PageTitle>

@if (_loading)
{
    <div class="container" style="padding:2rem 0">
        <p>Loading…</p>
    </div>
}
else if (_product is null)
{
    <div class="container" style="padding:2rem 0">
        <p>Product not found.</p>
        <NavLink href="/" class="back-link">← Back to catalog</NavLink>
    </div>
}
else
{
    <div class="container">
        <NavLink href="/" class="back-link">← Back to catalog</NavLink>
        <div class="detail-layout">
            <div class="detail-gallery">
                <StoreProductImage Src="@_product.ImageUrl" Alt="@_product.Name" Loading="eager" />
            </div>
            <div class="detail-info">
                <p class="detail-meta">@_product.Tag · @StockStatusLabel(_product)</p>
                <h1>@_product.Name</h1>
                <p class="detail-price @(_product.IsOutOfStock || !_product.HasPrice ? "price-on-request text-muted" : "")">
                    @StorePriceFormatter.FormatListPrice(_product.IsOutOfStock, _product.Price)
                </p>
                <p class="detail-desc">@_product.Description</p>
                @if (_options.Count > 0)
                {
                    <StoreProductOptionsForm Options="_options" OnChanged="OnOptionsChanged" />
                }
                <div class="qty-row">
                    <div class="qty-control">
                        <button type="button" aria-label="Decrease" @onclick="DecreaseQty" disabled="@(!_product.HasPrice)">−</button>
                        <span>@_quantity</span>
                        <button type="button" aria-label="Increase" @onclick="IncreaseQty" disabled="@(!_product.HasPrice)">+</button>
                    </div>
                    <button type="button" class="btn btn-primary" disabled="@(!_product.HasPrice || _product.IsOutOfStock || !_optionsValid)" @onclick="AddToCartAsync">
                        @(_product.IsOutOfStock
                            ? StorePriceFormatter.OutOfStockLabel
                            : _product.HasPrice ? "Add to cart" : StorePriceFormatter.OnRequestLabel)
                    </button>
                </div>
                @if (_product.HasPrice && !_product.IsOutOfStock && !_optionsValid)
                {
                    <p class="product-option-hint">Please choose the required options above.</p>
                }
                @if (!string.IsNullOrEmpty(_addError))
                {
                    <p class="product-option-hint" style="color:#b42318">@_addError</p>
                }
                @if (!string.IsNullOrEmpty(_addSuccess))
                {
                    <p class="product-option-hint" style="color:#027a48">
                        @_addSuccess
                        <NavLink href="/cart">View cart</NavLink>
                    </p>
                }
                <p class="stock @(_product.IsOutOfStock ? "out" : _product.IsLowStock ? "low" : "")" style="font-size:0.85rem">@StockStatusLabel(_product)</p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int ProductId { get; set; }

    private StoreProduct? _product;
    private int _quantity = 1;
    private bool _loading = true;
    private IReadOnlyList<StoreProductOptionDto> _options = [];
    private IReadOnlyList<CartLineOption> _selectedOptions = [];
    private bool _optionsValid = true;

    private string? _addError;
    private string? _addSuccess;

    protected override async Task OnParametersSetAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        _addError = null;
        _addSuccess = null;
        try
        {
            var dto = await CatalogPort.GetByIdAsync(ProductId);
            _product = dto is null ? null : StoreProductMapper.ToModel(dto);
            _quantity = 1;
            _selectedOptions = [];
            _options = _product is null ? [] : await CatalogPort.GetProductOptionsAsync(ProductId);
            _optionsValid = !_options.Any(o => o.IsRequired);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnOptionsChanged(StoreProductOptionsForm.StoreProductOptionsState state)
    {
        _selectedOptions = state.Selected;
        _optionsValid = state.IsValid;
    }

    private void IncreaseQty()
    {
        if (_product is not null && _quantity < _product.Stock) _quantity++;
    }

    private void DecreaseQty()
    {
        if (_quantity > 1) _quantity--;
    }

    private async Task AddToCartAsync()
    {
        if (_product is null || !_product.HasPrice || !_optionsValid) return;
        _addError = null;
        _addSuccess = null;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        int? customerId = null;
        if (user.Identity?.IsAuthenticated == true
            && user.IsInRole(AppRoles.Customer)
            && int.TryParse(user.FindFirstValue(LegacyAuthClaims.CustomerId), out var id)
            && id > 0)
        {
            customerId = id;
        }

        await Cart.BindToCustomerAsync(customerId);
        var added = await Cart.AddProductAsync(_product.Id, _quantity, _selectedOptions);
        if (!added)
        {
            _addError = "Could not add this product to your cart. Please try again.";
            return;
        }

        // Stay on the product page so the shopper can keep adding — no empty-cart flash.
        _addSuccess = $"Added to cart ({Cart.ItemCount} item{(Cart.ItemCount == 1 ? "" : "s")}).";
        _quantity = 1;
    }

    private static string StockStatusLabel(StoreProduct product) =>
        product.IsOutOfStock ? StorePriceFormatter.OutOfStockLabel : $"{product.Stock} in stock";
}
