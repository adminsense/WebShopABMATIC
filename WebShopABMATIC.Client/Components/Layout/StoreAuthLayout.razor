@inherits LayoutComponentBase

<div class="store-shell">
    <StoreStaffRedirect />
    <StoreHeader ShowSidebar="false" />
    <main class="store-auth-main">
        @Body
    </main>
</div>

@implements IDisposable

@code {
    [Inject] private StoreCartService Cart { get; set; } = default!;

    protected override void OnInitialized() => Cart.Changed += OnCartChanged;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Cart.EnsureLoadedAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose() => Cart.Changed -= OnCartChanged;
}
