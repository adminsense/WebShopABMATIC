@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        var returnUrl = string.IsNullOrEmpty(relative) ? "/" : "/" + relative;

        if (relative.StartsWith("admin", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo(
                $"/admin/login?returnUrl={Uri.EscapeDataString(returnUrl)}",
                forceLoad: true);
            return;
        }

        Navigation.NavigateTo(
            $"/sign-in?returnUrl={Uri.EscapeDataString(returnUrl)}",
            forceLoad: true);
    }
}
