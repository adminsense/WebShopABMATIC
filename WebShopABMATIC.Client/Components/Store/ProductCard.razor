@using WebShopABMATIC.Web.Services

<article class="product-card" @onclick="() => OnSelect.InvokeAsync(Product.Id)">
  <div class="img-wrap">
    @if (Product.IsNew)
    {
      <span class="product-badge-new">New</span>
    }
    <StoreProductImage Src="@Product.ImageUrl" Alt="@Product.Name" />
  </div>
  <div class="body">
    <p class="category">@Product.Tag</p>
    <h3>@Product.Name</h3>
    <p class="brand">@Product.Description</p>
    <div class="price-row">
      <span class="price @(Product.IsOutOfStock || !Product.HasPrice ? "price-on-request text-muted" : "")">
        @StorePriceFormatter.FormatListPrice(Product.IsOutOfStock, Product.Price)
      </span>
      <span class="stock @(Product.IsOutOfStock ? "out" : Product.IsLowStock ? "low" : "")">
        @(Product.IsOutOfStock ? StorePriceFormatter.OutOfStockLabel : $"{Product.Stock} in stock")
      </span>
    </div>
  </div>
</article>

@code {
    [Parameter, EditorRequired] public StoreProduct Product { get; set; } = default!;
    [Parameter] public EventCallback<int> OnSelect { get; set; }
}
