@using WebShopABMATIC.Application.Auth
@inject NavigationManager Navigation
@inject StoreCartService Cart
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor
@inject IJSRuntime Js

<header class="site-header">
    <div class="header-inner store-header-nav">
        <nav class="store-header-links" aria-label="Store navigation">
            <button type="button" class="store-header-link" @onclick="GoBackAsync">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
                <span>Back</span>
            </button>
            <NavLink href="/" class="store-header-link" Match="NavLinkMatch.All">
                <i class="bi bi-house" aria-hidden="true"></i>
                <span>Home</span>
            </NavLink>
            <NavLink href="/cart" class="store-header-link">
                <i class="bi bi-cart3" aria-hidden="true"></i>
                <span>Cart</span>
                @if (Cart.ItemCount > 0)
                {
                    <span class="cart-badge">@Cart.ItemCount</span>
                }
            </NavLink>
            <NavLink href="/contact" class="store-header-link">
                <i class="bi bi-compass" aria-hidden="true"></i>
                <span>Contact</span>
            </NavLink>
        </nav>

        <div class="store-header-search">
            <input type="search"
                   class="store-search-input"
                   placeholder="Search products…"
                   aria-label="Search products"
                   @bind="_search"
                   @bind:event="oninput"
                   @onkeydown="OnSearchKey" />
            <button type="button" class="store-search-btn" @onclick="SubmitSearchAsync">
                <i class="bi bi-search" aria-hidden="true"></i>
                <span>Search</span>
            </button>
        </div>

        <div class="store-header-auth">
            @if (_isAuthenticated)
            {
                @if (_isCustomer)
                {
                    <NavLink href="/my-account" class="store-header-link" title="@_displayName">
                        <i class="bi bi-person" aria-hidden="true"></i>
                        <span>@ShortName(_displayName)</span>
                    </NavLink>
                }
                else
                {
                    <span class="store-header-user" title="@_displayName">@ShortName(_displayName)</span>
                }
                <button type="button" class="store-header-link store-header-link--btn" @onclick="SignOutAsync">
                    <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                    <span>Sign out</span>
                </button>
            }
            else
            {
                <NavLink href="/sign-in" class="store-header-link" data-enhance-nav="false">
                    <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                    <span>Login</span>
                </NavLink>
            }
        </div>
    </div>
</header>

@code {
    [Parameter] public bool ShowSidebar { get; set; } = true;

    private string _search = "";
    private bool _isAuthenticated;
    private bool _isCustomer;
    private string _displayName = "";

    protected override async Task OnInitializedAsync()
    {
        Cart.Changed += () => InvokeAsync(StateHasChanged);
        ReadSearchFromUri();
        await LoadUserAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        ReadSearchFromUri();
        await LoadUserAsync();
    }

    private void ReadSearchFromUri()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .TryGetValue("q", out var value))
        {
            _search = value.FirstOrDefault() ?? "";
        }
    }

    private async Task LoadUserAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _isAuthenticated = user.Identity?.IsAuthenticated == true;
        _isCustomer = user.IsInRole(AppRoles.Customer);

        if (_isAuthenticated)
        {
            _displayName = user.FindFirst(LegacyAuthClaims.DisplayName)?.Value
                ?? user.Identity?.Name
                ?? "Account";
        }
    }

    private static string ShortName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
        {
            return "Account";
        }

        return name.Length <= 18 ? name : name[..15] + "…";
    }

    private async Task SignOutAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            await Infrastructure.Auth.LegacyCookieAuthentication.SignOutAsync(httpContext);
        }

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task GoBackAsync()
    {
        await Js.InvokeVoidAsync("eval", "if (window.history.length > 1) { history.back(); } else { window.location.href = '/'; }");
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitSearchAsync();
        }
    }

    private Task SubmitSearchAsync()
    {
        var term = _search.Trim();
        var url = string.IsNullOrEmpty(term)
            ? BuildCatalogUrl(null)
            : $"{BuildCatalogUrl(null)}&q={Uri.EscapeDataString(term)}";
        Navigation.NavigateTo(url);
        return Task.CompletedTask;
    }

    private static string BuildCatalogUrl(int? categoryId) =>
        categoryId is int id ? $"/?categoryId={id}" : "/";
}
