@using WebShopABMATIC.Application.Auth
@inject NavigationManager Navigation
@inject StoreCartService Cart
@inject AuthenticationStateProvider AuthStateProvider
@inject IHttpContextAccessor HttpContextAccessor

<header class="site-header">
    <div class="header-inner">
        <a href="/" class="logo">Web<span>Shop</span></a>
        <div class="search-bar">
            <span class="search-icon" aria-hidden="true">
                <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                    <circle cx="6.75" cy="6.75" r="4.25" />
                    <path d="M10.25 10.25 14 14" />
                </svg>
            </span>
            <input type="search" placeholder="Search products..." aria-label="Search"
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKey" />
        </div>
        <nav class="nav-actions">
            <NavLink href="/" class="nav-btn" Match="NavLinkMatch.All">Catalog</NavLink>
            <NavLink href="/orders" class="nav-btn">My orders</NavLink>
            @if (_isCustomer)
            {
                <NavLink href="/my-account" class="nav-btn">My account</NavLink>
            }
            <NavLink href="/cart" class="nav-btn">
                Cart <span class="cart-badge">@Cart.ItemCount</span>
            </NavLink>
            <div class="user-menu">
                @if (_isAuthenticated)
                {
                    <span class="user-display-name @(_isStaff ? "staff-user" : "")" title="@_displayName">@_displayName</span>
                    <button type="button" class="nav-btn nav-btn-text" @onclick="SignOutAsync">Sign out</button>
                }
                else
                {
                    <NavLink href="/sign-in" class="nav-btn" data-enhance-nav="false">Sign in</NavLink>
                }
            </div>
            <a href="@AdminHref" class="nav-btn" data-enhance-nav="false" title="Staff admin panel">Admin</a>
        </nav>
    </div>
</header>

@code {
    private string _search = "";
    private bool _isAuthenticated;
    private bool _isStaff;
    private bool _isCustomer;
    private string _displayName = "";

    [Parameter] public EventCallback<string> OnSearch { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Cart.Changed += () => InvokeAsync(StateHasChanged);
        await LoadUserAsync();
    }

    protected override async Task OnParametersSetAsync() => await LoadUserAsync();

    private async Task LoadUserAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _isAuthenticated = user.Identity?.IsAuthenticated == true;
        _isStaff = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Manager);
        _isCustomer = user.IsInRole(AppRoles.Customer);

        if (_isAuthenticated)
        {
            _displayName = user.FindFirst(LegacyAuthClaims.DisplayName)?.Value
                ?? user.Identity?.Name
                ?? "Account";
        }
    }

    private string AdminHref => _isStaff ? "/admin" : "/admin/login";

    private async Task SignOutAsync()
    {
        var httpContext = HttpContextAccessor.HttpContext;
        if (httpContext is not null)
        {
            await Infrastructure.Auth.LegacyCookieAuthentication.SignOutAsync(httpContext);
        }

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && OnSearch.HasDelegate)
            await OnSearch.InvokeAsync(_search);
    }
}
