@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Store
@using WebShopABMATIC.Web.Services
@using Microsoft.JSInterop
@inject NavigationManager Navigation
@inject StoreCartService Cart
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime Js
@inject IStoreCatalogPort CatalogPort

<header class="site-header">
    <div class="store-header-box">
        <nav class="store-header-bar" aria-label="Store navigation">
            <button type="button"
                    class="store-header-link store-header-link--icon"
                    aria-label="Back"
                    @onclick="GoBackAsync">
                <i class="bi bi-arrow-left" aria-hidden="true"></i>
            </button>
            <NavLink href="/" class="store-header-link" Match="NavLinkMatch.All">
                <i class="bi bi-house" aria-hidden="true"></i>
                <span>Home</span>
            </NavLink>
            <NavLink href="/cart" class="store-header-link">
                <i class="bi bi-cart3" aria-hidden="true"></i>
                <span>Cart</span>
                @if (Cart.ItemCount > 0)
                {
                    <span class="cart-badge">@Cart.ItemCount</span>
                }
            </NavLink>
            <NavLink href="/contact" class="store-header-link">
                <i class="bi bi-compass" aria-hidden="true"></i>
                <span>Contact</span>
            </NavLink>
            <input type="search"
                   class="store-header-search-input"
                   placeholder=""
                   aria-label="Search products"
                   @bind="_search"
                   @bind:event="oninput"
                   @onkeydown="OnSearchKey" />
            <button type="button" class="store-header-link store-header-link--btn" @onclick="SubmitSearchAsync">
                <i class="bi bi-search" aria-hidden="true"></i>
                <span>Search</span>
            </button>
            @if (_isAuthenticated)
            {
                @if (_isCustomer)
                {
                    <NavLink href="/orders" class="store-header-link">
                        <i class="bi bi-bag-check" aria-hidden="true"></i>
                        <span>My orders</span>
                    </NavLink>
                    <NavLink href="/my-account" class="store-header-link" title="@_displayName">
                        <i class="bi bi-person" aria-hidden="true"></i>
                        <span>@ShortName(_displayName)</span>
                    </NavLink>
                }
                else if (_isStaff)
                {
                    <NavLink href="/admin" class="store-header-link" data-enhance-nav="false">
                        <i class="bi bi-gear" aria-hidden="true"></i>
                        <span>Admin</span>
                    </NavLink>
                    <span class="store-header-user" title="@_displayName">@ShortName(_displayName)</span>
                }
                else
                {
                    <span class="store-header-user" title="@_displayName">@ShortName(_displayName)</span>
                }
                <button type="button" class="store-header-link store-header-link--btn" @onclick="SignOutAsync">
                    <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                    <span>Sign out</span>
                </button>
            }
            else
            {
                <NavLink href="/sign-in" class="store-header-link" data-enhance-nav="false">
                    <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                    <span>Login</span>
                </NavLink>
                <NavLink href="/admin/login" class="store-header-link" data-enhance-nav="false">
                    <i class="bi bi-gear" aria-hidden="true"></i>
                    <span>Admin</span>
                </NavLink>
            }
        </nav>
    </div>
</header>

<StoreSearchModal Visible="@_searchModalOpen"
                  SearchTerm="@_searchModalTerm"
                  Loading="@_searchLoading"
                  Results="@_searchResults"
                  OnClose="CloseSearchModal"
                  OnSelect="GoToProductFromSearchAsync" />

@implements IDisposable

@code {
    [Parameter] public bool ShowSidebar { get; set; } = true;

    private string _search = "";
    private bool _searchModalOpen;
    private bool _searchLoading;
    private string _searchModalTerm = "";
    private IReadOnlyList<StoreProduct> _searchResults = [];
    private bool _isAuthenticated;
    private bool _isCustomer;
    private bool _isStaff;
    private string _displayName = "";
    private bool _idleMonitorStarted;

    protected override async Task OnInitializedAsync()
    {
        Cart.Changed += OnCartChanged;
        ReadSearchFromUri();
        await LoadUserAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Bind + load after browser storage is available (login/full reload).
            await LoadUserAsync();
            await InvokeAsync(StateHasChanged);
        }

        await SyncSessionTimeoutAsync();
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Cart.Changed -= OnCartChanged;
        _ = StopSessionTimeoutAsync();
    }

    private async Task SyncSessionTimeoutAsync()
    {
        try
        {
            if (_isAuthenticated && _isCustomer)
            {
                if (_idleMonitorStarted)
                {
                    return;
                }

                await Js.InvokeVoidAsync(
                    "storeSessionTimeout.start",
                    (int)Infrastructure.Auth.LegacyCookieAuthentication.SessionIdleTimeout.TotalMinutes);
                _idleMonitorStarted = true;
            }
            else if (_idleMonitorStarted)
            {
                await Js.InvokeVoidAsync("storeSessionTimeout.stop");
                _idleMonitorStarted = false;
            }
        }
        catch (JSException)
        {
            // Script may not be ready on first static paint.
        }
        catch (InvalidOperationException)
        {
            // JS interop unavailable during static rendering.
        }
    }

    private async Task StopSessionTimeoutAsync()
    {
        try
        {
            if (_idleMonitorStarted)
            {
                await Js.InvokeVoidAsync("storeSessionTimeout.stop");
                _idleMonitorStarted = false;
            }
        }
        catch
        {
            // Ignore dispose-time failures.
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        ReadSearchFromUri();
        await LoadUserAsync();
    }

    private void ReadSearchFromUri()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .TryGetValue("q", out var value))
        {
            _search = value.FirstOrDefault() ?? "";
        }
    }

    private async Task LoadUserAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        _isAuthenticated = user.Identity?.IsAuthenticated == true;
        _isCustomer = user.IsInRole(AppRoles.Customer);
        _isStaff = user.IsInRole(AppRoles.Admin) || user.IsInRole(AppRoles.Manager);

        int? customerId = null;
        if (_isAuthenticated && _isCustomer
            && int.TryParse(user.FindFirst(LegacyAuthClaims.CustomerId)?.Value, out var id)
            && id > 0)
        {
            customerId = id;
        }

        await Cart.BindToCustomerAsync(customerId);

        if (_isAuthenticated)
        {
            _displayName = user.FindFirst(LegacyAuthClaims.DisplayName)?.Value
                ?? user.Identity?.Name
                ?? "Account";
        }
    }

    private static string ShortName(string name) =>
        string.IsNullOrWhiteSpace(name) ? "Account" : name.Length <= 18 ? name : name[..15] + "…";

    private async Task SignOutAsync()
    {
        try
        {
            await StopSessionTimeoutAsync();
        }
        catch
        {
            // Ignore — circuit is about to unload.
        }

        try
        {
            await Cart.BindToCustomerAsync(null);
        }
        catch
        {
            // Ignore — logout navigation is authoritative.
        }

        // Full page load so the cookie is cleared before any response body starts.
        Navigation.NavigateTo("/account/logout?returnUrl=/", forceLoad: true);
    }

    private async Task GoBackAsync()
    {
        var currentCategoryId = ReadCategoryIdFromUri();
        if (currentCategoryId is int categoryId)
        {
            var tree = await CatalogPort.GetCategoryTreeAsync();
            var currentNode = FindNodeById(tree, categoryId);
            if (currentNode?.ParentId is int parentId)
            {
                Navigation.NavigateTo($"/?categoryId={parentId}");
                return;
            }

            Navigation.NavigateTo("/");
            return;
        }

        await Js.InvokeVoidAsync("eval", "if (window.history.length > 1) { history.back(); } else { window.location.href = '/'; }");
    }

    private int? ReadCategoryIdFromUri()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .TryGetValue("categoryId", out var value)
            && int.TryParse(value.FirstOrDefault(), out var id)
            && id > 0)
        {
            return id;
        }

        return null;
    }

    private static StoreCategoryTreeNodeDto? FindNodeById(
        IReadOnlyList<StoreCategoryTreeNodeDto> nodes,
        int targetId)
    {
        foreach (var node in nodes)
        {
            if (node.Id == targetId)
            {
                return node;
            }

            var found = FindNodeById(node.Children, targetId);
            if (found is not null)
            {
                return found;
            }
        }

        return null;
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitSearchAsync();
        }
    }

    private async Task SubmitSearchAsync()
    {
        var term = _search.Trim();
        if (string.IsNullOrEmpty(term))
        {
            CloseSearchModal();
            return;
        }

        _searchModalTerm = term;
        _searchModalOpen = true;
        _searchLoading = true;
        _searchResults = [];
        StateHasChanged();

        try
        {
            var items = await CatalogPort.SearchProductsAsync(term, take: 24);
            _searchResults = items
                .Select(StoreProductMapper.ToModel)
                .ToList();
        }
        finally
        {
            _searchLoading = false;
            StateHasChanged();
        }
    }

    private void CloseSearchModal()
    {
        _searchModalOpen = false;
        _searchLoading = false;
        _searchModalTerm = "";
        _searchResults = [];
    }

    private Task GoToProductFromSearchAsync(int productId)
    {
        CloseSearchModal();
        Navigation.NavigateTo($"/product/{productId}");
        return Task.CompletedTask;
    }
}
