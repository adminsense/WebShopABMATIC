@using WebShopABMATIC.Web.Services
@inject StoreCartService Cart

<article class="deal-card">
    <button type="button" class="deal-card-image-btn" @onclick="() => OnSelect.InvokeAsync(Product.Id)">
        <img src="@Product.ImageUrl" alt="@Product.Name" loading="lazy" decoding="async" />
    </button>
    <div class="deal-card-body">
        <button type="button" class="deal-card-title-btn" @onclick="() => OnSelect.InvokeAsync(Product.Id)">
            @Product.Name.ToUpperInvariant()
        </button>
        @if (!string.IsNullOrWhiteSpace(Product.Description))
        {
            <p class="deal-card-description">@Product.Description</p>
        }
        <div class="deal-card-footer">
            <span class="deal-card-price @(!Product.HasPrice ? "text-muted" : "")">
                @StorePriceFormatter.Format(Product.Price)
            </span>
            @if (Product.HasPrice && !Product.IsOutOfStock)
            {
                <button type="button"
                        class="deal-card-cart-btn"
                        title="Add to cart"
                        aria-label="Add @Product.Name to cart"
                        @onclick="AddToCartAsync"
                        @onclick:stopPropagation="true">
                    <i class="bi bi-cart-plus"></i>
                </button>
            }
        </div>
    </div>
</article>

@code {
    [Parameter, EditorRequired] public StoreProduct Product { get; set; } = default!;
    [Parameter] public EventCallback<int> OnSelect { get; set; }

    private async Task AddToCartAsync() => await Cart.AddProductAsync(Product.Id);
}
