@using WebShopABMATIC.Application.Store

@if (Node.Children.Count > 0)
{
    <div class="store-nav-group">
        <div class="store-nav-row">
            <button type="button"
                    class="store-nav-toggle"
                    aria-expanded="@IsExpanded"
                    @onclick="ToggleExpand">
                <i class="bi @(IsExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
            </button>
            <a href="@CategoryHref(Node.Id)"
               class="store-nav-link @(IsActive ? "active" : "")">
                @Node.Name
            </a>
        </div>
        @if (IsExpanded)
        {
            <ul class="store-nav-children">
                @foreach (var child in Node.Children)
                {
                    <li>
                        <CategoryNode Node="child"
                                      SelectedCategoryId="SelectedCategoryId"
                                      ExpandedIds="ExpandedIds"
                                      OnToggle="OnToggle" />
                    </li>
                }
            </ul>
        }
    </div>
}
else
{
    <a href="@CategoryHref(Node.Id)"
       class="store-nav-link store-nav-link--leaf @(IsActive ? "active" : "")">
        @Node.Name
    </a>
}

@code {
    [Parameter, EditorRequired] public StoreCategoryTreeNodeDto Node { get; set; } = default!;
    [Parameter] public int? SelectedCategoryId { get; set; }
    [Parameter] public IReadOnlySet<int> ExpandedIds { get; set; } = new HashSet<int>();
    [Parameter] public EventCallback<int> OnToggle { get; set; }

    private bool IsExpanded => ExpandedIds.Contains(Node.NavigationKey);

    private bool IsActive => SelectedCategoryId == Node.Id;

    private static string CategoryHref(int id) => $"/?categoryId={id}";

    private Task ToggleExpand() => OnToggle.InvokeAsync(Node.NavigationKey);
}
