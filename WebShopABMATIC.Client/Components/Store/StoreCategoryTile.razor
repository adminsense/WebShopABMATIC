@using WebShopABMATIC.Application.Store

<button type="button"
        class="category-tile"
        @onclick="() => OnSelect.InvokeAsync(Category.Id)">
    <span class="category-tile-icon" aria-hidden="true">
        @if (Category.HasIcon && !_iconFailed)
        {
            <img src="@($"/api/store/category-icon/{Category.Id}")"
                 alt=""
                 loading="lazy"
                 decoding="async"
                 @onerror="OnIconError" />
        }
        else
        {
            <i class="bi bi-box-seam"></i>
        }
    </span>
    <span class="category-tile-label">@Category.Name</span>
</button>

@code {
    [Parameter, EditorRequired] public StoreCategoryTreeNodeDto Category { get; set; } = default!;
    [Parameter] public EventCallback<int> OnSelect { get; set; }

    private bool _iconFailed;

    private void OnIconError() => _iconFailed = true;
}
