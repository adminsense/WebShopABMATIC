@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Web.Services
@inject StoreCartService Cart
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<button type="button"
        class="@CssClass"
        title="@Title"
        aria-label="@AriaLabel"
        disabled="@IsOutOfStock"
        @onclick="OnClickAsync"
        @onclick:stopPropagation="true">
    <i class="bi bi-cart3" aria-hidden="true"></i>
</button>

@code {
    [Parameter, EditorRequired] public StoreProduct Product { get; set; } = default!;
    [Parameter] public string CssClass { get; set; } = "product-cart-btn";

    private bool IsOutOfStock => Product.IsOutOfStock;

    private bool NeedsPriceLogin => !Product.HasPrice && !IsOutOfStock;

    private bool NeedsOptions => Product.HasOptions && !NeedsPriceLogin && !IsOutOfStock;

    private string Title => IsOutOfStock
        ? "Unavailable"
        : NeedsPriceLogin
            ? "Sign in to see price"
            : NeedsOptions
                ? "Choose options"
                : "Add to cart";

    private string AriaLabel => IsOutOfStock
        ? $"Cannot add {Product.Name} to cart"
        : NeedsPriceLogin
            ? $"Sign in to add {Product.Name} to cart"
            : NeedsOptions
                ? $"Choose options for {Product.Name}"
                : $"Add {Product.Name} to cart";

    private async Task OnClickAsync()
    {
        if (IsOutOfStock)
        {
            return;
        }

        var returnUrl = NeedsOptions ? $"/product/{Product.Id}" : "/cart";

        if (NeedsPriceLogin)
        {
            Navigation.NavigateTo($"/sign-in?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
            return;
        }

        if (!await EnsureCustomerCartAsync())
        {
            Navigation.NavigateTo($"/sign-in?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
            return;
        }

        if (NeedsOptions)
        {
            Navigation.NavigateTo($"/product/{Product.Id}");
            return;
        }

        await Cart.AddProductAsync(Product.Id);
        Navigation.NavigateTo("/cart");
    }

    private async Task<bool> EnsureCustomerCartAsync()
    {
        if (Cart.IsCustomerCart)
        {
            return true;
        }

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!int.TryParse(auth.User.FindFirstValue(LegacyAuthClaims.CustomerId), out var customerId) || customerId <= 0)
        {
            return false;
        }

        await Cart.BindToCustomerAsync(customerId);
        return Cart.IsCustomerCart;
    }
}
