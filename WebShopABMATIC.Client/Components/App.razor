<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ImportMap />
    <link rel="icon" href="/images/product1.png" type="image/png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/open-iconic/1.1.1/font/css/open-iconic-bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/app.css" />
    <link rel="stylesheet" href="/css/store.css" />
    <link rel="stylesheet" href="/css/mollie-mock.css" />
    <link rel="stylesheet" href="/css/admin.css" />
    <link rel="stylesheet" href="/css_abmatic/validation.css" />
    <link rel="stylesheet" href="/WebShopABMATIC.styles.css" />
    <HeadOutlet @rendermode="PageRenderMode" />
</head>

<body>
    <Routes @rendermode="PageRenderMode" />
    @* .NET 10 fingerprints framework JS — hardcoded path 404s → blank page when prerender was off. *@
    <script src="@Assets["_framework/blazor.web.js"]"></script>
    <script src="/_content/WebShopABMATIC.Client/js/store-password-toggle.js"></script>
    <script src="/_content/WebShopABMATIC.Client/js/store-session-timeout.js"></script>
    <script src="/_content/WebShopABMATIC.Client/js/admin-export.js"></script>
</body>

</html>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private IComponentRenderMode? PageRenderMode =>
        UsesStaticRendering ? null : AppRenderModes.InteractiveServer;

    private bool UsesStaticRendering
    {
        get
        {
            var path = HttpContext?.Request.Path ?? PathString.Empty;
            return path.StartsWithSegments("/Account", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWithSegments("/admin/login", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWithSegments("/sign-in", StringComparison.OrdinalIgnoreCase)
                   || path.StartsWithSegments("/sign-up", StringComparison.OrdinalIgnoreCase)
                   // Payment host page must SSR even if Blazor JS fails to load.
                   || path.StartsWithSegments("/checkout/mollie-mock", StringComparison.OrdinalIgnoreCase);
        }
    }
}
