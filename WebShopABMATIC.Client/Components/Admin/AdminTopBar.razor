@using WebShopABMATIC.Application.Auth
@inject AuthenticationStateProvider AuthStateProvider

<div class="admin-topbar">
    <span>Hello, <strong>@_displayName</strong></span>
    <form action="/account/logout" method="post" class="d-inline m-0">
        <input type="hidden" name="returnUrl" value="/admin/login" />
        <button type="submit" class="btn-logout" title="Logout">
            <span class="oi oi-power-standby"></span> Logout
        </button>
    </form>
</div>

@code {
    private string _displayName = "STAFF";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            _displayName = (user.FindFirst(LegacyAuthClaims.DisplayName)?.Value
                ?? user.Identity.Name
                ?? "STAFF").ToUpperInvariant();
        }
    }
}
