@using WebShopABMATIC.Application.Audit

<span class="audit-action-badge @CssClass">@Action</span>

@code {
    [Parameter, EditorRequired] public string Action { get; set; } = "";

    private string CssClass => Action switch
    {
        AuditActions.Create => "audit-badge-create",
        AuditActions.Update => "audit-badge-update",
        AuditActions.Delete => "audit-badge-delete",
        AuditActions.Login => "audit-badge-login",
        AuditActions.LoginFailed => "audit-badge-login-failed",
        AuditActions.Logout => "audit-badge-logout",
        AuditActions.ReportExport => "audit-badge-report",
        AuditActions.CheckoutStarted => "audit-badge-checkout",
        AuditActions.PaymentPaid => "audit-badge-payment",
        AuditActions.PasswordReset => "audit-badge-password",
        AuditActions.StockAdjust => "audit-badge-stock",
        _ => "audit-badge-default"
    };
}
