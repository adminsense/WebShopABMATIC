@using Microsoft.AspNetCore.Identity
@using WebShopABMATIC.Infrastructure.Identity
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<div class="admin-topbar">
    <span>Hello, <strong>@_displayName</strong></span>
    <form action="Account/Logout" method="post" class="d-inline m-0">
        <AntiforgeryToken />
        <input type="hidden" name="returnUrl" value="" />
        <button type="submit" class="btn-logout" title="Logout">
            <span class="oi oi-power-standby"></span> Logout
        </button>
    </form>
</div>

@code {
    private string _displayName = "STAFF";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var appUser = await UserManager.GetUserAsync(user);
            _displayName = appUser?.DisplayName.ToUpperInvariant() ?? user.Identity.Name?.ToUpperInvariant() ?? "STAFF";
        }
    }
}
