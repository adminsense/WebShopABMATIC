@page "/cart"
@layout StoreLayout
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Ports.Outbound
@using WebShopABMATIC.Application.Store.Checkout
@inject StoreCartService CartService
@inject ICheckoutPort CheckoutPort
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Cart</PageTitle>

<div class="container">
    <h1 class="page-title">Your cart</h1>

    @if (CartService.Lines.Count == 0)
    {
        <p style="color:var(--muted);margin-bottom:1.5rem">Your cart is empty.</p>
        <NavLink href="/" class="btn btn-primary">Continue shopping</NavLink>
    }
    else
    {
        <div class="cart-layout">
            <div class="cart-table">
                @foreach (var line in CartService.Lines)
                {
                    <div class="cart-row" @key="line.ProductId">
                        <img src="@line.ImageUrl" alt="@line.Name" />
                        <div>
                            <h4>@line.Name</h4>
                            <p class="unit">@FormatPrice(line.UnitPrice) each</p>
                        </div>
                        <div class="qty-control">
                            <button type="button" @onclick="() => CartService.SetQuantity(line.ProductId, line.Quantity - 1)">−</button>
                            <span>@line.Quantity</span>
                            <button type="button" @onclick="() => CartService.SetQuantity(line.ProductId, line.Quantity + 1)">+</button>
                        </div>
                        <span class="line-total">@FormatPrice(line.LineTotal)</span>
                        <button type="button" class="remove-btn" title="Remove" @onclick="() => CartService.Remove(line.ProductId)">×</button>
                    </div>
                }
            </div>
            <aside class="summary-card">
                <h3>Order summary</h3>
                @if (_quote is not null)
                {
                    <div class="summary-line"><span>Subtotal (@CartService.ItemCount items)</span><span>@FormatPrice(_quote.Subtotal)</span></div>
                    <div class="summary-line"><span>Delivery</span><span>Standard — @FormatPrice(_quote.DeliveryFee)</span></div>
                    <div class="summary-line"><span>VAT 21%</span><span>@FormatPrice(_quote.VatAmount)</span></div>
                    <div class="summary-line total"><span>Total</span><span>@FormatPrice(_quote.Total)</span></div>
                }
                else
                {
                    <div class="summary-line"><span>Subtotal (@CartService.ItemCount items)</span><span>@FormatPrice(CartService.Subtotal)</span></div>
                    <div class="summary-line"><span>Delivery</span><span>Standard — @FormatPrice(CartService.DeliveryFee)</span></div>
                    <div class="summary-line"><span>VAT 21%</span><span>@FormatPrice(CartService.VatAmount)</span></div>
                    <div class="summary-line total"><span>Total</span><span>@FormatPrice(CartService.Total)</span></div>
                }

                @if (!string.IsNullOrEmpty(_checkoutError))
                {
                    <div class="alert alert-danger mt-2 mb-0 small">@_checkoutError</div>
                }
                @if (_quote?.Errors.Count > 0)
                {
                    <div class="alert alert-warning mt-2 mb-0 small">
                        @foreach (var err in _quote.Errors)
                        {
                            <div>@err</div>
                        }
                    </div>
                }

                @if (_options is not null)
                {
                    <div class="form-group" style="margin-top:1rem">
                        <label>Delivery address</label>
                        <select class="form-control" @bind="_deliveryAddressId">
                            @foreach (var addr in _options.DeliveryAddresses)
                            {
                                <option value="@addr.Id">@addr.Label</option>
                            }
                        </select>
                    </div>
                    <div class="form-group" style="margin-top:0.75rem">
                        <label>Payment method</label>
                        <select class="form-control" @bind="_paymentMethodId">
                            @foreach (var pm in _options.PaymentMethods)
                            {
                                <option value="@pm.Id">@pm.Name</option>
                            }
                        </select>
                    </div>
                }

                <button type="button" class="btn btn-primary" disabled="@_placing" @onclick="PlaceOrderAsync">
                    @(_placing ? "Processing…" : "Place order")
                </button>
            </aside>
        </div>
    }
</div>

@code {
    private CheckoutOptionsDto? _options;
    private CheckoutQuoteDto? _quote;
    private int _deliveryAddressId;
    private int _paymentMethodId = 1;
    private string? _checkoutError;
    private bool _placing;
    private string? _userEmail;
    private string? _identityUserId;

    protected override void OnInitialized() => CartService.Changed += OnCartChanged;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userEmail = auth.User.Identity?.Name;
        _identityUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (!string.IsNullOrEmpty(_userEmail))
        {
            _options = await CheckoutPort.GetOptionsAsync(UserLookup());
            if (_options?.DeliveryAddresses.Count > 0)
            {
                _deliveryAddressId = _options.DeliveryAddresses[0].Id;
            }
            if (_options?.PaymentMethods.Count > 0)
            {
                _paymentMethodId = _options.PaymentMethods[0].Id;
            }
        }

        await RefreshQuoteAsync();
    }

    private async void OnCartChanged()
    {
        await RefreshQuoteAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshQuoteAsync()
    {
        if (string.IsNullOrEmpty(_userEmail) || CartService.Lines.Count == 0)
        {
            _quote = null;
            return;
        }

        _quote = await CheckoutPort.BuildQuoteAsync(new CheckoutQuoteRequest
        {
            UserEmail = _userEmail,
            IdentityUserId = _identityUserId,
            Lines = CartService.Lines.Select(l => new CheckoutLineRequest
            {
                ProductId = l.ProductId,
                Quantity = l.Quantity
            }).ToList()
        });
    }

    private async Task PlaceOrderAsync()
    {
        _checkoutError = null;
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated != true)
        {
            Navigation.NavigateTo("/sign-in?returnUrl=/cart", forceLoad: true);
            return;
        }

        var email = auth.User.Identity?.Name ?? "";
        if (CartService.Lines.Count == 0)
        {
            return;
        }

        _placing = true;
        try
        {
            var baseUrl = Navigation.BaseUri.TrimEnd('/');
            var result = await CheckoutPort.PlaceOrderAsync(new CheckoutRequest
            {
                Lines = CartService.Lines.Select(l => new CheckoutLineRequest
                {
                    ProductId = l.ProductId,
                    Quantity = l.Quantity
                }).ToList(),
                DeliveryAddressId = _deliveryAddressId,
                PaymentMethodId = _paymentMethodId,
                RedirectBaseUrl = baseUrl,
                WebhookBaseUrl = baseUrl
            }, new StoreUserLookup
            {
                Email = email,
                IdentityUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier)
            });

            if (!result.Success)
            {
                _checkoutError = string.Join(" ", result.Errors);
                return;
            }

            CartService.Clear();

            if (!string.IsNullOrEmpty(result.RedirectUrl))
            {
                Navigation.NavigateTo(result.RedirectUrl, forceLoad: true);
            }
            else if (!string.IsNullOrEmpty(result.ConfirmationUrl))
            {
                Navigation.NavigateTo(result.ConfirmationUrl, forceLoad: true);
            }
            else
            {
                Navigation.NavigateTo("/orders", forceLoad: true);
            }
        }
        finally
        {
            _placing = false;
        }
    }

    private StoreUserLookup UserLookup() => new() { Email = _userEmail, IdentityUserId = _identityUserId };

    private static string FormatPrice(decimal price) => $"€{price:F2}";
}
