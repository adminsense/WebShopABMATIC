@page "/"
@layout StoreLayout
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Store
@inject IStoreCatalogPort CatalogPort
@inject NavigationManager Navigation

<PageTitle>WebShop — Catalog</PageTitle>

<section class="hero container">
    <div class="hero-grid">
        <div>
            <h1>ABMATIC webshop</h1>
            <p>Browse our product catalog, add to cart, and check out in a few clicks.</p>
            <div class="hero-cta">
                <a href="#products" class="btn btn-primary">Browse catalog</a>
                <NavLink href="/cart" class="btn btn-outline">View cart</NavLink>
            </div>
        </div>
        <div class="hero-visual">
            <img src="/images/product1.png" alt="Featured product" />
        </div>
    </div>
</section>

<section class="container" id="products">
    <h2 class="section-title">Categories</h2>
    @if (_categories.Count == 0 && !_loading)
    {
        <p class="text-muted">No categories configured for the webshop yet.</p>
    }
    else
    {
        <div class="categories">
            <button type="button" class="chip @(_selectedCategoryId is null ? "active" : "")"
                    @onclick="() => SelectCategoryAsync(null)">All</button>
            @foreach (var cat in _categories)
            {
                <button type="button" class="chip @(_selectedCategoryId == cat.Id ? "active" : "")"
                        @onclick="() => SelectCategoryAsync(cat.Id)">@cat.Name (@cat.ProductCount)</button>
            }
        </div>
    }

    <h2 class="section-title">Products</h2>
    @if (_loading)
    {
        <p class="text-muted">Loading catalog…</p>
    }
    else if (_products.Count == 0)
    {
        <p class="text-muted">No products available in this category.</p>
    }
    else
    {
        <div class="product-grid">
            @foreach (var p in _products)
            {
                <article class="product-card" @onclick="() => GoToProduct(p.Id)">
                    <div class="img-wrap"><img src="@p.ImageUrl" alt="@p.Name" /></div>
                    <div class="body">
                        <p class="category">@p.Tag</p>
                        <h3>@p.Name</h3>
                        <p class="brand">@p.Description</p>
                        <div class="price-row">
                            <span class="price @(!p.HasPrice ? "text-muted" : "")">@StorePriceFormatter.Format(p.Price)</span>
                            <span class="stock @(p.IsOutOfStock ? "out" : p.IsLowStock ? "low" : "")">@(p.IsOutOfStock ? "Out of stock" : $"{p.Stock} in stock")</span>
                        </div>
                    </div>
                </article>
            }
        </div>
    }
</section>

@code {
    private const int HomePageProductLimit = 12;

    private int? _selectedCategoryId;
    private bool _loading = true;
    private IReadOnlyList<StoreCatalogCategoryDto> _categories = [];
    private IReadOnlyList<StoreProduct> _products = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _categories = await CatalogPort.GetCategoriesAsync();
            var items = await CatalogPort.GetCatalogAsync(HomePageProductLimit, _selectedCategoryId);
            _products = items.Select(StoreProductMapper.ToModel).ToList();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SelectCategoryAsync(int? categoryId)
    {
        _selectedCategoryId = categoryId;
        await LoadAsync();
    }

    private void GoToProduct(int id) => Navigation.NavigateTo($"/product/{id}");
}
