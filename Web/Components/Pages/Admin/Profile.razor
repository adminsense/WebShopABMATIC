@page "/admin/profile"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using System.ComponentModel.DataAnnotations
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports.Outbound
@using WebShopABMATIC.Web.Forms

@inject ILegacyStaffProfilePort StaffProfile
@inject ICurrentUserContext CurrentUser

<PageTitle>My profile</PageTitle>

<div class="entity-page">
    <a class="btn btn-secondary btn-back mb-3" href="/admin/hub/profile" data-enhance-nav="false"><span class="oi oi-arrow-left"></span> Back to profile hub</a>
    <div class="entity-page-header page-header">
        <h1 class="h3 mb-1"><i class="bi bi-person text-primary"></i> My profile</h1>
        <p class="mb-0">Update your legacy staff account (<c>Instellingen.User</c>).</p>
    </div>

    @if (_loading)
    {
        <p class="text-muted">Loading…</p>
    }
    else if (_profile is null)
    {
        <div class="alert alert-danger">Could not load your profile.</div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(_statusMessage))
        {
            <div class="alert @(_statusIsError ? "alert-danger" : "alert-success")">@_statusMessage</div>
        }

        <div class="card shadow-sm border entity-form-card admin-form-card" style="max-width:640px">
            <div class="card-header card-header-catalog"><h2 class="h6 mb-0 fw-bold">Account details</h2></div>
            <div class="card-body">
                <EditForm Model="_profileModel" OnValidSubmit="SaveProfileAsync">
                    <DataAnnotationsValidator />
                    <div class="entity-form-fields">
                        <div class="row g-2">
                            <div class="col-md-6">
                                <label class="form-label" for="f-login">Login</label>
                                <input id="f-login" class="form-control form-control-sm" value="@_profile.Login" disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="f-email">Email</label>
                                <input id="f-email" type="email" class="form-control form-control-sm" value="@_profile.Email" disabled />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="f-first">First name</label>
                                <InputText id="f-first" class="form-control form-control-sm" @bind-Value="_profileModel.FirstName" />
                                <ValidationMessage For="() => _profileModel.FirstName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="f-last">Last name</label>
                                <InputText id="f-last" class="form-control form-control-sm" @bind-Value="_profileModel.LastName" />
                                <ValidationMessage For="() => _profileModel.LastName" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="f-phone">Phone</label>
                                <InputText id="f-phone" class="form-control form-control-sm" @bind-Value="_profileModel.PhoneNumber" />
                                <ValidationMessage For="() => _profileModel.PhoneNumber" />
                            </div>
                            <div class="col-12 d-flex gap-2 pt-1">
                                <button type="submit" class="btn btn-primary" disabled="@_saving">Save profile</button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>

        <div class="card shadow-sm border entity-form-card admin-form-card mt-3" style="max-width:640px">
            <div class="card-header card-header-catalog"><h2 class="h6 mb-0 fw-bold">Change password</h2></div>
            <div class="card-body">
                <EditForm Model="_passwordModel" OnValidSubmit="ChangePasswordAsync">
                    <DataAnnotationsValidator />
                    <div class="entity-form-fields">
                        <div class="row g-2">
                            <div class="col-md-12">
                                <label class="form-label" for="f-current">Current password</label>
                                <InputText id="f-current" type="password" class="form-control form-control-sm" @bind-Value="_passwordModel.CurrentPassword" />
                                <ValidationMessage For="() => _passwordModel.CurrentPassword" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="f-new">New password</label>
                                <InputText id="f-new" type="password" class="form-control form-control-sm" @bind-Value="_passwordModel.NewPassword" />
                                <ValidationMessage For="() => _passwordModel.NewPassword" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="f-confirm">Confirm new password</label>
                                <InputText id="f-confirm" type="password" class="form-control form-control-sm" @bind-Value="_passwordModel.ConfirmPassword" />
                                <ValidationMessage For="() => _passwordModel.ConfirmPassword" />
                            </div>
                            <div class="col-12 d-flex gap-2 pt-1">
                                <button type="submit" class="btn btn-outline-primary" disabled="@_saving">Update password</button>
                            </div>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    }
</div>

@code {
    private LegacyStaffProfileDto? _profile;
    private AdminProfileFormModel _profileModel = new();
    private AdminPasswordFormModel _passwordModel = new();
    private bool _loading = true;
    private bool _saving;
    private string? _statusMessage;
    private bool _statusIsError;
    private int? _staffUserId;

    protected override async Task OnInitializedAsync()
    {
        var current = await CurrentUser.GetCurrentUserAsync();
        _staffUserId = current.StaffUserId;
        if (_staffUserId is int staffUserId)
        {
            _profile = await StaffProfile.GetAsync(staffUserId);
            if (_profile is not null)
            {
                _profileModel = new AdminProfileFormModel
                {
                    FirstName = _profile.FirstName,
                    LastName = _profile.LastName,
                    PhoneNumber = _profile.Phone
                };
            }
        }

        _loading = false;
    }

    private async Task SaveProfileAsync()
    {
        if (_staffUserId is not int staffUserId)
        {
            return;
        }

        _saving = true;
        _statusMessage = null;
        try
        {
            var (succeeded, error) = await StaffProfile.SaveAsync(staffUserId, new LegacyStaffProfileUpdate
            {
                FirstName = _profileModel.FirstName ?? "",
                LastName = _profileModel.LastName ?? "",
                Phone = _profileModel.PhoneNumber
            });

            if (!succeeded)
            {
                _statusIsError = true;
                _statusMessage = error ?? "Could not save profile.";
                return;
            }

            _profile = await StaffProfile.GetAsync(staffUserId);
            _statusIsError = false;
            _statusMessage = "Profile saved.";
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        if (_staffUserId is not int staffUserId)
        {
            return;
        }

        _saving = true;
        _statusMessage = null;
        try
        {
            var (succeeded, error) = await StaffProfile.ChangePasswordAsync(
                staffUserId,
                _passwordModel.CurrentPassword,
                _passwordModel.NewPassword);

            if (!succeeded)
            {
                _statusIsError = true;
                _statusMessage = error ?? "Could not update password.";
                return;
            }

            _passwordModel = new AdminPasswordFormModel();
            _statusIsError = false;
            _statusMessage = "Password updated.";
        }
        finally
        {
            _saving = false;
        }
    }
}
