@page "/admin/stock/movements"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Admin.Stock
@using WebShopABMATIC.Application.Common
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Web.Services
@inject IStockMovementAdminPort MovementPort

@inject IGridExportService GridExport
@implements IAsyncDisposable

<PageTitle>Movement journal</PageTitle>

<div class="entity-page">
    <a class="btn btn-secondary btn-back mb-3" href="/admin/hub/stock" data-enhance-nav="false"><span class="oi oi-arrow-left"></span> Back to Stock hub</a>
    <div class="entity-page-header page-header">
        <h1 class="h3 mb-1"><i class="bi bi-journal-text text-primary"></i> Movement journal</h1>
        <p class="mb-0">Historical stock movements (read-only).</p>
    </div>

    <div class="card shadow-sm border entity-grid-card">
        <div class="card-header bg-white border-bottom py-3 d-flex flex-wrap align-items-end justify-content-between gap-3">
            <div class="d-flex align-items-center gap-2"><h2 class="h6 mb-0 fw-bold">Movements</h2><AdminExportDropdown Disabled="@ExportDisabled" OnExport="ExportGridAsync" /></div>
            <div class="d-flex flex-wrap gap-2 align-items-end">
                <div>
                    <label class="form-label small mb-0">From</label>
                    <input type="date" class="form-control form-control-sm" @bind="_filterFrom" />
                </div>
                <div>
                    <label class="form-label small mb-0">To</label>
                    <input type="date" class="form-control form-control-sm" @bind="_filterTo" />
                </div>
                <div>
                    <label class="form-label small mb-0">Search product</label>
                    <input type="search" class="form-control form-control-sm" placeholder="Name or ID‚Ä¶" @bind="_searchDraft" @bind:event="oninput" />
                </div>
                <div class="form-check mb-1">
                    <input type="checkbox" class="form-check-input" id="f-res" @bind="_reservationsOnly" />
                    <label class="form-check-label small" for="f-res">Reservations only</label>
                </div>
                <button type="button" class="btn btn-primary btn-sm" @onclick="ApplyFiltersAsync">Apply</button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Date/time</th>
                        <th>Product</th>
                        <th>Location</th>
                        <th class="text-end">Qty</th>
                        <th>Res.</th>
                        <th>Order line</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_loading)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Loading‚Ä¶</td></tr>
                    }
                    else if (_result is null || _result.Items.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No movements found.</td></tr>
                    }
                    else
                    {
                        @foreach (var item in _result.Items)
                        {
                            <tr @key="item.Id">
                                <td>@item.Timestamp.ToLocalTime().ToString("g")</td>
                                <td>
                                    <strong>@item.ProductName</strong>
                                    <div class="small text-muted">#@item.ProductId ¬∑ @item.PartNumber</div>
                                </td>
                                <td>@item.LocationName</td>
                                <td class="text-end @(item.Quantity >= 0 ? "text-success" : "text-danger")">@item.Quantity.ToString("+0.####;-0.####;0")</td>
                                <td>@(item.IsReservation ? "Yes" : "‚Äî")</td>
                                <td>@(item.OrderLineId?.ToString() ?? "‚Äî")</td>
                                <td class="small">@(item.Notes ?? "‚Äî")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <AdminGridPagination TotalCount="@(_result?.TotalCount ?? 0)" Page="@(_filter.Page)" PageSize="@(_filter.PageSize)" Loading="@_loading" OnPageChanged="ChangePageAsync" />
    </div>
</div>

@code {
    private StockMovementListFilter _filter = new();
    private PagedResult<StockMovementDto>? _result;
    private string _searchDraft = "";
    private DateTime? _filterFrom;
    private DateTime? _filterTo;
    private bool _reservationsOnly;
    private bool _loading = true;
    private CancellationTokenSource? _cts;

    protected override async Task OnInitializedAsync() => await LoadGridAsync();

    private async Task LoadGridAsync()
    {
        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        _loading = true;
        try
        {
            _result = await MovementPort.GetMovementsAsync(_filter, _cts.Token);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ChangePageAsync(int page)
    {
        if (page < 1) return;
        _filter.Page = page;
        await LoadGridAsync();
    }
    private async Task ApplyFiltersAsync()
    {
        _filter.Search = string.IsNullOrWhiteSpace(_searchDraft) ? null : _searchDraft.Trim();
        _filter.FromDate = _filterFrom;
        _filter.ToDate = _filterTo;
        _filter.ReservationsOnly = _reservationsOnly ? true : null;
        _filter.Page = 1;
        await LoadGridAsync();
    }

    private bool ExportDisabled => _loading || _result is null || _result.Items.Count == 0;

    private async Task ExportGridAsync(string format)
    {
        var request = BuildExportRequest();
        if (request is not null)
        {
            await GridExport.ExportAsync(format, request);
        }
    }

    private GridExportRequest? BuildExportRequest()
    {
        return GridExportBuilder.FromRows(
            "movements",
            "Movements",
            new[] { "Date/time", "Product", "Location", "Qty", "Reservation", "Notes" },
            _result?.Items.Select(item => (IReadOnlyList<string>)new[]
            {
                GridExportBuilder.Cell(item.Timestamp.ToLocalTime().ToString("g")),
                GridExportBuilder.Cell($"{item.ProductName} (#{item.ProductId} ∑ {item.PartNumber})"),
                GridExportBuilder.Cell(item.LocationName),
                GridExportBuilder.Cell(item.Quantity.ToString("+0.####;-0.####;0")),
                GridExportBuilder.Cell(item.IsReservation ? "Yes" : "ó"),
                GridExportBuilder.Cell(item.Notes ?? "ó")
            }));
    }
    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}




