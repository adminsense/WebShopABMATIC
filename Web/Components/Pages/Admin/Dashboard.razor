@page "/admin"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@inject IAdminDashboardPort DashboardPort
@implements IAsyncDisposable

<PageTitle>Admin â€” Start</PageTitle>

@if (_loading)
{
    <p class="text-muted">Loading dashboardâ€¦</p>
}
else if (_dashboard is not null)
{
    var acceptancePct = Pct(_dashboard.AcceptedOrdersThisMonth, _dashboard.OrdersThisMonth);
    var webshopPct = Pct(_dashboard.ProductsOnWebshop, _dashboard.TotalProducts);
    var imagePct = Pct(_dashboard.ProductImages, _dashboard.ProductsOnWebshop);
    var stockHealthPct = Pct(_dashboard.TotalProducts - _dashboard.LowStockAlerts, _dashboard.TotalProducts);
    var marginPct = _dashboard.RevenueYtd > 0
        ? PctDecimal(_dashboard.NetYtd, _dashboard.RevenueYtd)
        : 0;
    var itemsMonthSharePct = PctDecimal(_dashboard.ItemsSoldThisMonth, _dashboard.ItemsSoldYtd);
    var stockFillPct = PctDecimal(_dashboard.TotalStockUnits, _dashboard.TotalStockCapacity);
    var lowStockRiskPct = Pct(_dashboard.LowStockAlerts, _dashboard.TotalProducts);
    var outstandingPct = PctDecimal(_dashboard.OutstandingRevenueYtd, _dashboard.PaidRevenueYtd + _dashboard.OutstandingRevenueYtd);
    var costSharePct = PctDecimal(_dashboard.CostsYtd, _dashboard.RevenueYtd);
    var customerCoveragePct = Pct(_dashboard.TotalCustomers, _dashboard.TotalProjects);
    var ordersMonthSharePct = Pct(_dashboard.OrdersThisMonth, _dashboard.OrdersYtd);

    <div class="dash-page">
        <div class="dash-grid">
            <div class="portfolio-card portfolio-card--compact">
                <h3>
                    <span class="icon-circle purple"><span class="oi oi-cog"></span></span>
                    Webshop catalog
                </h3>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Products on webshop</div>
                            <div class="stat-band-value">@webshopPct% Â· @_dashboard.ProductsOnWebshop / @_dashboard.TotalProducts published</div>
                        </div>
                        <span class="pill pill-green"><i class="bi bi-box-seam me-1"></i>@_dashboard.ProductsOnWebshop/@_dashboard.TotalProducts</span>
                    </div>
                    <div class="progress-thin"><span style="width:@(webshopPct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">B2B customers</div>
                            <div class="stat-band-value">@customerCoveragePct% Â· @_dashboard.TotalCustomers customers Â· @_dashboard.TotalProjects projects</div>
                        </div>
                        <span class="pill pill-blue"><i class="bi bi-people me-1"></i>@_dashboard.TotalCustomers</span>
                    </div>
                    <div class="progress-thin"><span style="width:@(customerCoveragePct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Product images</div>
                            <div class="stat-band-value">@imagePct% Â· @_dashboard.ProductImages / @_dashboard.ProductsOnWebshop with image</div>
                        </div>
                        <span class="pill pill-purple"><i class="bi bi-image me-1"></i>@_dashboard.ProductImages/@_dashboard.ProductsOnWebshop</span>
                    </div>
                    <div class="progress-thin"><span style="width:@(imagePct)%"></span></div>
                </div>
            </div>

            <div class="portfolio-card portfolio-card--compact">
                <h3>
                    <span class="icon-circle red"><span class="oi oi-cart"></span></span>
                    Sales &amp; orders
                </h3>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Order acceptance (this month)</div>
                            <div class="stat-band-value">@acceptancePct% Â· @_dashboard.AcceptedOrdersThisMonth / @_dashboard.OrdersThisMonth accepted</div>
                        </div>
                        <span class="pill pill-green"><i class="bi bi-check-circle me-1"></i>@_dashboard.AcceptedOrdersThisMonth/@_dashboard.OrdersThisMonth</span>
                    </div>
                    <div class="progress-thin"><span style="width:@(acceptancePct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Items sold (this month)</div>
                            <div class="stat-band-value">@itemsMonthSharePct% of YTD Â· @_dashboard.ItemsSoldThisMonth.ToString("N0") units Â· @_dashboard.RevenueThisMonth.ToString("N2") â‚¬</div>
                        </div>
                        <span class="pill pill-blue"><i class="bi bi-cart-check me-1"></i>@_dashboard.ItemsSoldThisMonth.ToString("N0")</span>
                    </div>
                    <div class="progress-thin progress-thin--info"><span style="width:@(itemsMonthSharePct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Pending acceptance</div>
                            <div class="stat-band-value">@PendingPct(_dashboard)% Â· @_dashboard.PendingOrders orders Â· @_dashboard.PendingOrderValue.ToString("N2") â‚¬</div>
                        </div>
                        <span class="pill pill-red"><i class="bi bi-exclamation-triangle me-1"></i>@_dashboard.PendingOrders</span>
                    </div>
                    <div class="progress-thin progress-thin--danger"><span style="width:@(PendingPct(_dashboard))%"></span></div>
                </div>
            </div>

            <div class="portfolio-card portfolio-card--compact">
                <h3>
                    <span class="icon-circle blue"><span class="oi oi-box"></span></span>
                    Stock &amp; warehouse
                </h3>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Stock health</div>
                            <div class="stat-band-value">@stockHealthPct% Â· @(_dashboard.TotalProducts - _dashboard.LowStockAlerts) / @_dashboard.TotalProducts above minimum</div>
                        </div>
                        <span class="pill pill-green"><i class="bi bi-boxes me-1"></i>@stockHealthPct%</span>
                    </div>
                    <div class="progress-thin"><span style="width:@(stockHealthPct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Warehouse fill level</div>
                            <div class="stat-band-value">@stockFillPct% Â· @_dashboard.TotalStockUnits.ToString("N0") / @_dashboard.TotalStockCapacity.ToString("N0") units</div>
                        </div>
                        <span class="pill pill-blue"><i class="bi bi-stack me-1"></i>@stockFillPct%</span>
                    </div>
                    <div class="progress-thin progress-thin--info"><span style="width:@(stockFillPct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Low stock &amp; out of stock</div>
                            <div class="stat-band-value">@lowStockRiskPct% at risk Â· @_dashboard.LowStockAlerts low Â· @_dashboard.OutOfStockProducts zero</div>
                        </div>
                        <span class="pill pill-red"><i class="bi bi-exclamation-circle me-1"></i>@_dashboard.LowStockAlerts/@_dashboard.OutOfStockProducts</span>
                    </div>
                    <div class="progress-thin progress-thin--danger"><span style="width:@(lowStockRiskPct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Movements (7 days) Â· open POs</div>
                            <div class="stat-band-value">@_dashboard.StockMovementsLast7Days movements Â· @_dashboard.OpenPurchaseOrders open purchase orders</div>
                        </div>
                        <a class="pill pill-blue" href="/admin/stock/movements" data-enhance-nav="false"><i class="bi bi-journal-text me-1"></i>Journal</a>
                    </div>
                </div>
            </div>

            <div class="portfolio-card portfolio-card--compact">
                <h3>
                    <span class="icon-circle green"><span class="oi oi-dollar"></span></span>
                    Financial overview
                </h3>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Net margin (YTD)</div>
                            <div class="stat-band-value">@marginPct% Â· @_dashboard.NetYtd.ToString("N2") â‚¬ net on @_dashboard.RevenueYtd.ToString("N2") â‚¬</div>
                        </div>
                        <span class="pill pill-green"><i class="bi bi-percent me-1"></i>@marginPct%</span>
                    </div>
                    <div class="progress-thin"><span style="width:@(marginPct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Cost share (YTD)</div>
                            <div class="stat-band-value">@costSharePct% Â· @_dashboard.CostsYtd.ToString("N2") â‚¬ costs of @_dashboard.RevenueYtd.ToString("N2") â‚¬ revenue</div>
                        </div>
                        <span class="pill pill-red"><i class="bi bi-receipt me-1"></i>@costSharePct%</span>
                    </div>
                    <div class="progress-thin progress-thin--danger"><span style="width:@(costSharePct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Outstanding vs accepted</div>
                            <div class="stat-band-value">@outstandingPct% open Â· @_dashboard.OutstandingRevenueYtd.ToString("N2") â‚¬ of @_dashboard.PaidRevenueYtd.ToString("N2") â‚¬ accepted</div>
                        </div>
                        <span class="pill pill-red"><i class="bi bi-clock me-1"></i>@outstandingPct%</span>
                    </div>
                    <div class="progress-thin progress-thin--danger"><span style="width:@(outstandingPct)%"></span></div>
                </div>
                <div class="dash-metric">
                    <div class="stat-band">
                        <div>
                            <div class="stat-band-label">Volume YTD</div>
                            <div class="stat-band-value">@_dashboard.ItemsSoldYtd.ToString("N0") units Â· @_dashboard.OrdersYtd orders Â· @_dashboard.WebshopStructureNodes catalog nodes</div>
                        </div>
                        <span class="pill pill-blue"><i class="bi bi-graph-up me-1"></i>@_dashboard.OrdersYtd</span>
                    </div>
                    <div class="progress-thin progress-thin--info"><span style="width:@(ordersMonthSharePct)%"></span></div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private CancellationTokenSource? _cts;
    private bool _loading = true;
    private WebShopABMATIC.Application.Admin.Dashboard.AdminDashboardDto? _dashboard;
    private bool _loaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded)
            return;

        _cts = new CancellationTokenSource();
        await LoadAsync(_cts.Token);
        _loaded = true;
    }

    private static int Pct(int part, int total)
    {
        if (total <= 0)
            return 0;

        return Math.Clamp((int)Math.Round(100.0 * part / total), 0, 100);
    }

    private static int PctDecimal(decimal part, decimal total)
    {
        if (total <= 0)
            return 0;

        return Math.Clamp((int)Math.Round(100.0 * (double)(part / total)), 0, 100);
    }

    private static int PendingPct(WebShopABMATIC.Application.Admin.Dashboard.AdminDashboardDto d) =>
        Pct(d.PendingOrders, d.OrdersThisMonth);

    private async Task LoadAsync(CancellationToken ct)
    {
        _loading = true;
        try
        {
            _dashboard = await DashboardPort.GetDashboardAsync(ct);
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}



