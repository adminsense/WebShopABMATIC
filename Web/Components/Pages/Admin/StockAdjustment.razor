@page "/admin/stock/adjustment"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Admin.Stock
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@using WebShopABMATIC.Application.Stock
@inject IStockAdjustmentPort AdjustmentPort
@implements IAsyncDisposable

<PageTitle>Stock adjustment</PageTitle>

<div class="entity-page">
    <a class="btn btn-secondary btn-back mb-3" href="/admin/hub/stock" data-enhance-nav="false">
        <span class="oi oi-arrow-left"></span> Back to Stock hub
    </a>
    <div class="entity-page-header page-header">
        <h1 class="h3 mb-1"><i class="bi bi-arrow-left-right text-primary"></i> Stock adjustment</h1>
        <p class="mb-0">Record manual inbound (+) or outbound (−) stock corrections. Does not replace product-stock master data.</p>
    </div>

    <div class="card shadow-sm border entity-form-card admin-form-card">
        <div class="card-header bg-white">
            <h2 class="h6 mb-0 fw-bold">New adjustment</h2>
        </div>
        <div class="card-body">
            @if (_loadingLookups)
            {
                <p class="text-muted mb-0">Loading…</p>
            }
            else
            {
                <EditForm Model="_model" OnValidSubmit="ApplyAsync">
                    <DataAnnotationsValidator />
                    <div class="entity-form-fields">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label" for="adj-product">Product ID *</label>
                                <InputNumber id="adj-product" class="form-control form-control-sm" @bind-Value="_model.ProductId" @bind-Value:after="RefreshPreviewAsync" />
                                <ValidationMessage For="@(() => _model.ProductId)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="adj-location">Stock location *</label>
                                <InputSelect id="adj-location" class="form-select form-select-sm" @bind-Value="_model.StockLocationId" @bind-Value:after="RefreshPreviewAsync">
                                    @foreach (var loc in _lookups?.StockLocations ?? [])
                                    {
                                        <option value="@loc.Id">@loc.Name (@loc.Id)</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => _model.StockLocationId)" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" for="adj-change">Quantity change *</label>
                                <InputNumber id="adj-change" class="form-control form-control-sm" @bind-Value="_model.QuantityChange" />
                                <div class="form-text">Positive = stock in · negative = stock out</div>
                                <ValidationMessage For="@(() => _model.QuantityChange)" />
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="adj-reason">Reason *</label>
                                <InputText id="adj-reason" class="form-control form-control-sm" @bind-Value="_model.Reason" maxlength="150" />
                                <ValidationMessage For="@(() => _model.Reason)" />
                            </div>

                            @if (_previewLoading)
                            {
                                <div class="col-12"><span class="text-muted small">Loading current balance…</span></div>
                            }
                            else if (_preview is not null)
                            {
                                <div class="col-12">
                                    <div class="alert alert-secondary mb-0 py-2">
                                        <strong>@_preview.ProductName</strong> at <strong>@_preview.StockLocationName</strong> —
                                        current on hand: <strong>@_preview.CurrentQuantity.ToString("N2")</strong>
                                        @if (_model.QuantityChange != 0)
                                        {
                                            <span> → after adjustment: <strong>@((_preview.CurrentQuantity + _model.QuantityChange).ToString("N2"))</strong></span>
                                        }
                                    </div>
                                </div>
                            }
                            else if (_previewChecked)
                            {
                                <div class="col-12">
                                    <div class="alert alert-warning mb-0 py-2">
                                        No product-stock row for this product and location.
                                        <a href="/admin/product-stock" data-enhance-nav="false">Create one first</a>.
                                    </div>
                                </div>
                            }

                            <div class="col-12 d-flex gap-2 pt-1">
                                <button type="submit" class="btn btn-primary" disabled="@(_saving || _preview is null)">
                                    @(_saving ? "Saving…" : "Apply adjustment")
                                </button>
                                <button type="button" class="btn btn-secondary" @onclick="ResetForm" disabled="@_saving">Clear</button>
                                <a class="btn btn-outline-secondary" href="/admin/stock/movements" data-enhance-nav="false">View journal</a>
                            </div>
                        </div>
                    </div>
                </EditForm>

                @if (!string.IsNullOrEmpty(_formError))
                {
                    <div class="alert alert-danger mt-3 mb-0">@_formError</div>
                }
                @if (!string.IsNullOrEmpty(_successMessage))
                {
                    <div class="alert alert-success mt-3 mb-0">@_successMessage</div>
                }
            }
        </div>
    </div>
</div>

@code {
    private CancellationTokenSource? _cts;
    private StockAdjustmentRequest _model = new() { StockLocationId = 1, ProductId = 1, QuantityChange = 1 };
    private StockAdjustmentLookupsDto? _lookups;
    private StockAdjustmentPreviewDto? _preview;
    private bool _loadingLookups = true;
    private bool _previewLoading;
    private bool _previewChecked;
    private bool _saving;
    private bool _disposed;
    private string? _formError;
    private string? _successMessage;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadLookupsAsync(_cts.Token);
        await RefreshPreviewAsync();
    }

    private async Task LoadLookupsAsync(CancellationToken ct)
    {
        _loadingLookups = true;
        try
        {
            _lookups = await AdjustmentPort.GetLookupsAsync(ct);
            if (_lookups.StockLocations.Count > 0 && !_lookups.StockLocations.Any(l => l.Id == _model.StockLocationId))
            {
                _model.StockLocationId = _lookups.StockLocations[0].Id;
            }
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _loadingLookups = false;
        }
    }

    private async Task RefreshPreviewAsync()
    {
        if (_model.ProductId <= 0 || _model.StockLocationId <= 0)
        {
            _preview = null;
            _previewChecked = false;
            return;
        }

        _previewLoading = true;
        _previewChecked = false;
        _successMessage = null;
        try
        {
            _preview = await AdjustmentPort.GetPreviewAsync(
                _model.ProductId,
                _model.StockLocationId,
                _cts?.Token ?? CancellationToken.None);
            _previewChecked = true;
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _previewLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplyAsync()
    {
        _saving = true;
        _formError = null;
        _successMessage = null;
        try
        {
            var result = await AdjustmentPort.ApplyAsync(_model, _cts?.Token ?? CancellationToken.None);
            if (result.Status == StockApplyStatus.Failed)
            {
                _formError = string.Join(" ", result.Errors);
                return;
            }

            _successMessage = result.NewBalance is decimal balance
                ? $"Adjustment saved. Movement #{result.MovementId}. New balance: {balance:N2}."
                : "Adjustment saved.";

            _model = new StockAdjustmentRequest
            {
                ProductId = _model.ProductId,
                StockLocationId = _model.StockLocationId,
                QuantityChange = 1,
                Reason = string.Empty
            };
            await RefreshPreviewAsync();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task ResetForm()
    {
        _formError = null;
        _successMessage = null;
        _model = new StockAdjustmentRequest
        {
            ProductId = 1,
            StockLocationId = _lookups?.StockLocations.FirstOrDefault()?.Id ?? 1,
            QuantityChange = 1,
            Reason = string.Empty
        };
        await RefreshPreviewAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        if (_cts is not null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}
