@page "/admin/products"
@layout AdminLayout
@attribute [Authorize(Policy = AppPolicies.AdminOrManager)]
@using WebShopABMATIC.Application.Admin.Products
@using WebShopABMATIC.Application.Auth
@using WebShopABMATIC.Application.Ports
@inject IProductAdminPort ProductPort
@implements IAsyncDisposable

<PageTitle>Product</PageTitle>

<div class="list-header">
    <h1><i class="bi bi-box-seam"></i> Product</h1>
    <div class="d-flex gap-2">
        <button type="button" class="btn btn-success btn-sm" @onclick="RefreshAsync">
            <i class="bi bi-arrow-repeat me-1"></i>Refresh
        </button>
        <a class="btn btn-primary btn-sm" href="/admin/products/new">+ Add product</a>
    </div>
</div>

<a class="btn btn-outline-secondary btn-sm mb-3" href="/admin/hub/catalog">
    <span class="oi oi-arrow-left"></span> Back
</a>

<div class="filter-panel">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label small">Search</label>
            <input class="form-control form-control-sm" @bind="_filter.Search" placeholder="Name, part number…" />
        </div>
        <div class="col-md-3">
            <label class="form-label small">Show on webshop</label>
            <select class="form-select form-select-sm" @bind="_showOnWebshopFilter">
                <option value="">All</option>
                <option value="true">Yes</option>
                <option value="false">No</option>
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-end">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" id="modifiedOnly" @bind="_filter.ModifiedOnly" />
                <label class="form-check-label small" for="modifiedOnly">Modified only</label>
            </div>
        </div>
    </div>
    <div class="filter-actions">
        <button type="button" class="btn btn-primary" @onclick="ApplyFiltersAsync">
            <i class="bi bi-funnel-fill me-1"></i>Apply Filters
        </button>
        <button type="button" class="btn btn-danger" @onclick="ClearFiltersAsync">
            <i class="bi bi-x-circle-fill me-1"></i>Clear
        </button>
    </div>
</div>

@if (_loading)
{
    <p class="text-muted">Loading…</p>
}
else if (_result?.Items.Count == 0)
{
    <div class="alert alert-info">No products found. Connect the domain database or add a product.</div>
}
else if (_result is not null)
{
    <div class="table-wrap">
        <table class="table table-striped table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ProductId</th>
                    <th>NameEn</th>
                    <th>ShowOnWebshop</th>
                    <th>SupplierId</th>
                    <th>ManufacturerId</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _result.Items)
                {
                    <tr @key="item.ProductId">
                        <td>@item.ProductId</td>
                        <td>@item.NameEn</td>
                        <td>@(item.ShowOnWebshop ? "true" : "false")</td>
                        <td>@item.SupplierId</td>
                        <td>@item.ManufacturerId</td>
                        <td class="text-center">
                            <a class="btn btn-sm btn-primary" href="/admin/products/@item.ProductId" title="Edit Product">
                                <i class="bi bi-pencil"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted small mt-2">@_result.TotalCount total · page @_result.Page</p>
}

@code {
    private CancellationTokenSource? _cts;
    private ProductListFilter _filter = new();
    private string _showOnWebshopFilter = string.Empty;
    private bool _loading = true;
    private WebShopABMATIC.Application.Common.PagedResult<ProductDto>? _result;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();
        await LoadAsync(_cts.Token);
    }

    private async Task LoadAsync(CancellationToken ct)
    {
        _loading = true;
        try
        {
            ApplyShowOnWebshopFilter();
            _result = await ProductPort.GetProductsAsync(_filter, ct);
        }
        finally
        {
            if (!ct.IsCancellationRequested) _loading = false;
        }
    }

    private void ApplyShowOnWebshopFilter() =>
        _filter.ShowOnWebshop = _showOnWebshopFilter switch
        {
            "true" => true,
            "false" => false,
            _ => null
        };

    private Task ApplyFiltersAsync() => LoadAsync(_cts?.Token ?? CancellationToken.None);
    private async Task ClearFiltersAsync()
    {
        _filter = new ProductListFilter();
        _showOnWebshopFilter = string.Empty;
        await LoadAsync(_cts?.Token ?? CancellationToken.None);
    }
    private Task RefreshAsync() => LoadAsync(_cts?.Token ?? CancellationToken.None);

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        await ValueTask.CompletedTask;
    }
}
